            if (!value.HasValue) return null;
            var x = points.Count == 1 ? 46 : 46 + (index * 454.0 / (points.Count - 1));
            var y = 220 - (value.Value / max * 192);
            return $"{x:0.##},{y:0.##}";
        }).Where(point => point is not null));
    }

    private double SimulationInfoXForIndex(int index)
    {
        var points = Result?.SimulationInfo ?? [];
        return points.Count == 1 ? 46 : 46 + (index * 454.0 / Math.Max(1, points.Count - 1));
    }

    private double SimulationInfoYForValue(double value)
    {
        return 220 - (value / SimulationInfoChartMax * 192);
    }

    private double SimulationInfoHoverX => SimulationInfoHoverIndex.HasValue ? SimulationInfoXForIndex(SimulationInfoHoverIndex.Value) : 46;

    private double SimulationInfoHoverLabelX => Math.Clamp(SimulationInfoHoverX - 27, 48, 446);

    private const int SimulationInfoMaxHoverLabels = 7;
    private double SimulationInfoHoverPanelWidth => 190;
    private double SimulationInfoHoverPanelHeight => 14 + Math.Min(SimulationInfoHoverMarkers.Count, SimulationInfoMaxHoverLabels) * 15 + (SimulationInfoHoverMarkers.Count > SimulationInfoMaxHoverLabels ? 15 : 0);
    private double SimulationInfoHoverPanelX => SimulationInfoHoverX > 300 ? 500 - SimulationInfoHoverPanelWidth : 300;
    private double SimulationInfoHoverPanelY => 56;
    private string SimulationInfoMoreHoverLabel => $"+{SimulationInfoHoverMarkers.Count - SimulationInfoMaxHoverLabels} more";

    private IReadOnlyList<(int Index, double X, double Width)> SimulationInfoHoverZones
    {
        get
        {
            var points = Result?.SimulationInfo ?? [];
            if (points.Count == 0) return [];
            if (points.Count == 1) return [(0, 46, 454)];

            var zones = new List<(int Index, double X, double Width)>();
            for (var index = 0; index < points.Count; index++)
            {
                var previousMid = index == 0 ? 46 : (SimulationInfoXForIndex(index - 1) + SimulationInfoXForIndex(index)) / 2;
                var nextMid = index == points.Count - 1 ? 500 : (SimulationInfoXForIndex(index) + SimulationInfoXForIndex(index + 1)) / 2;
                zones.Add((index, previousMid, nextMid - previousMid));
            }

            return zones;
        }
    }

    private IReadOnlyList<(double X, double Y, string Label, string Color)> SimulationInfoHoverMarkers
    {
        get
        {
            var points = Result?.SimulationInfo ?? [];
            if (!SimulationInfoHoverIndex.HasValue || SimulationInfoHoverIndex.Value < 0 || SimulationInfoHoverIndex.Value >= points.Count) return [];

            var index = SimulationInfoHoverIndex.Value;
            var year = points[index];
            var x = SimulationInfoXForIndex(index);
            var markers = new List<(double X, double Y, string Label, string Color)>();

            foreach (var row in SelectedSimulationInfoChartRows)
            {
                var color = SimulationInfoColor(row.Key);
                var value = row.ChartValue(year);
                if (value.HasValue)
                {
                    markers.Add((x, SimulationInfoYForValue(value.Value), $"{row.Metric}: {row.Formatter(value.Value)}", color));
                }

                var reference = row.ReferenceValue?.Invoke(year);
                if (reference.HasValue)
                {
                    markers.Add((x, SimulationInfoYForValue(reference.Value), $"{row.Metric} ref: {row.Formatter(reference.Value)}", color));
                }
            }

            return markers;
        }
    }

    private string SimulationInfoColor(string key)
    {
        var index = SimulationInfoRows.ToList().FindIndex(row => row.Key.Equals(key, StringComparison.OrdinalIgnoreCase));
        return ColorFor(Math.Max(0, index));
    }

    private static string ColorFor(int index)
    {
        var colors = new[] { "#0f766e", "#b45309", "#2563eb", "#7c3aed", "#be123c", "#4d7c0f", "#0f4c81", "#a16207" };
        return colors[index % colors.Length];
    }

    private static string FormatNullable(double? value) => value.HasValue ? value.Value.ToString("N0") : "n/a";

    private static IReadOnlyList<double> NormalizeUiWeights(params double[] weights)
    {
        var positive = weights.Select(weight => Math.Max(0, weight)).ToArray();
        var total = positive.Sum();
        return total > 0
            ? positive.Select(weight => weight / total).ToArray()
            : positive.Select(_ => 0.0).ToArray();
    }

    private static string FormatNormalized(double value)
    {
        return value switch
        {
            0 => "0",
            < 0.001 => "<0.1%",
            _ => value.ToString("P1")
        };
    }

    private static string FormatPoint(double value)
    {
        return value switch
        {
            0 => "0",
            < 0.0001 => "<0.0001",
            _ => value.ToString("0.####")
        };
    }

    private static string FormatCount(double value)
    {
        return value.ToString("N0");
    }

    private static string FormatGeneration(double value)
    {
        return value.ToString("0.000");
    }

    private static string FormatCountShare(double count, double share)
    {
        return $"{count:N0} ({share:P1})";
    }

    private static MarkupString SimulationCell(string modeled)
    {
        return new MarkupString($"<span>{modeled}</span>");
    }

    private static MarkupString SimulationCell(string modeled, double? reference, Func<double, string> formatter)
    {
        return reference.HasValue
            ? new MarkupString($"<span>{modeled}</span><small class=\"simulation-ref\">ref {formatter(reference.Value)}</small>")
            : SimulationCell(modeled);
    }

    private static string FormatElapsed(TimeSpan elapsed)
    {
        if (elapsed.TotalMinutes >= 1)
        {
            return $"{(int)elapsed.TotalMinutes:N0}m {elapsed.Seconds:N0}s";
        }

        if (elapsed.TotalSeconds >= 10)
        {
            return $"{elapsed.TotalSeconds:N0}s";
        }

        return $"{elapsed.TotalSeconds:0.0}s";
    }

    private static double ParseInputDouble(ChangeEventArgs args, double fallback)
    {
        return double.TryParse(args.Value?.ToString(), out var value) ? value : fallback;
    }

    private DensityEffectRow BuildDensityEffectRow(
        string label,
        string density,
        DensityFactorBinding firstFactor,
        DensityFactorBinding secondFactor,
        DensityFactorBinding thirdFactor)
    {
        return new DensityEffectRow(
            label,
            firstFactor,
            secondFactor,
            thirdFactor,
            Enumerable.Range(0, 5)
                .Select(child => new DensityChildEffect(
                    child,
                    EffectiveDensityMoveInShare(density, child),
                    EffectiveDensityBirthProbability(density, child)))
                .ToList());
    }

    private double EffectiveDensityMoveInShare(string density, int childNumber)
    {
        var zero = Math.Max(0, MoveInZeroChildShare);
        var one = Math.Max(0, MoveInOneChildShare) * DensityMoveInChildFactor(density, 1);
        var two = Math.Max(0, MoveInTwoChildShare) * DensityMoveInChildFactor(density, 2);
        var three = Math.Max(0, MoveInThreeChildShare) * DensityMoveInChildFactor(density, 3);
        var four = Math.Max(0, MoveInFourChildShare) * DensityMoveInChildFactor(density, 4);
        var total = zero + one + two + three + four;
        if (total <= 0) return 0;

        return childNumber switch
        {
            0 => zero / total,
            1 => one / total,
            2 => two / total,
            3 => three / total,
            4 => four / total,
            _ => 0
        };
    }

    private double EffectiveDensityBirthProbability(string density, int childNumber)
    {
        var baseProbability = childNumber switch
        {
            0 => 0,
            <= 1 => AnnualFirstNewChildProbability,
            2 => AnnualSecondNewChildProbability,
            3 => AnnualThirdNewChildProbability,
            _ => AnnualFourthPlusNewChildProbability
        };
        return Math.Clamp(baseProbability * DensityBirthMultiplier(density, childNumber), 0, 1);
    }

    private double DensityMoveInChildFactor(string density, int childNumber)
    {
        var profile = (NormalizeDensity(density), childNumber) switch
        {
            ("RMH", 1) => 0.95,
            ("RMH", 2) => 0.70,
            ("RMH", 3) => 0.20,
            ("RMH", _) => 0.05,
            ("RH", 1) => 0.90,
            ("RH", 2) => 0.50,
            ("RH", 3) => 0.05,
            ("RH", _) => 0.00,
            _ => 1.00
        };

        return profile * DensityGroupFactor(density) * DensityChildFactor(density, childNumber);
    }

    private double DensityBirthMultiplier(string density, int childNumber)
    {
        var profile = (NormalizeDensity(density), childNumber) switch
        {
            ("RMH", <= 1) => 0.95,
            ("RMH", 2) => 0.65,
            ("RMH", 3) => 0.15,
            ("RMH", _) => 0.05,
            ("RH", <= 1) => 0.85,
            ("RH", 2) => 0.45,
            ("RH", 3) => 0.05,
            ("RH", _) => 0.00,
            _ => 1.00
        };

        return profile * DensityGroupFactor(density) * DensityChildFactor(density, childNumber);
    }

    private double DensityGroupFactor(string density)
    {
        return NormalizeDensity(density) switch
        {
            "RMH" => DensityMediumHighFactor,
            "RH" => DensityHighFactor,
            _ => DensityLowMediumFactor
        };
    }

    private double DensityChildFactor(string density, int childNumber)
    {
        return (NormalizeDensity(density), childNumber) switch
        {
            ("RMH", <= 1) => DensityMediumHighFirstChildFactor,
            ("RMH", 2) => DensityMediumHighSecondChildFactor,
            ("RMH", 3) => DensityMediumHighThirdChildFactor,
            ("RH", <= 1) => DensityHighFirstChildFactor,
            ("RH", 2) => DensityHighSecondChildFactor,
            ("RH", 3) => DensityHighThirdChildFactor,
            (_, <= 1) => DensityLowMediumFirstChildFactor,
            (_, 2) => DensityLowMediumSecondChildFactor,
            (_, 3) => DensityLowMediumThirdChildFactor,
            _ => 1.0
        };
    }

    private static string NormalizeDensity(string density)
    {
        return density.Trim().ToUpperInvariant();
    }

    private sealed record MonteCarloToolDefinition(string Id, string Title);

    private sealed record SimulationInfoRow(
        string Group,
        string Metric,
        Func<MonteCarloSimulationYearInfo, MarkupString> Value,
        Func<MonteCarloSimulationYearInfo, double?> ChartValue,
        Func<MonteCarloSimulationYearInfo, double?>? ReferenceValue,
        Func<double, string> Formatter)
    {
        public string Key => $"{Group}|{Metric}";
    }

    private sealed record DensityEffectRow(
        string Label,
        DensityFactorBinding FirstFactor,
        DensityFactorBinding SecondFactor,
        DensityFactorBinding ThirdFactor,
        IReadOnlyList<DensityChildEffect> Children);

    private sealed record DensityChildEffect(int ChildNumber, double MoveInShare, double BirthProbability);

    private sealed class DensityFactorBinding(Func<double> getter, Action<double> setter)
    {
        public double Value
        {
            get => getter();
            set => setter(value);
        }
    }
}
