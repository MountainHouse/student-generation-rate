                        @foreach (var item in SimulationInfoHoverMarkers.Select((marker, index) => new { marker, index }))
                        {
                            <circle cx="@item.marker.X" cy="@item.marker.Y" r="4" fill="@item.marker.Color" class="chart-hover-dot" />
                        }
                        <rect x="@SimulationInfoHoverPanelX" y="@SimulationInfoHoverPanelY" width="@SimulationInfoHoverPanelWidth" height="@SimulationInfoHoverPanelHeight" rx="5" class="chart-hover-label-bg" />
                        @foreach (var item in SimulationInfoHoverMarkers.Take(SimulationInfoMaxHoverLabels).Select((marker, index) => new { marker, index }))
                        {
                            <circle cx="@(SimulationInfoHoverPanelX + 9)" cy="@(SimulationInfoHoverPanelY + 16 + item.index * 15)" r="3" fill="@item.marker.Color" class="chart-hover-dot" />
                            <SvgText X="@(SimulationInfoHoverPanelX + 16)" Y="@(SimulationInfoHoverPanelY + 20 + item.index * 15)" Anchor="start" Label="@item.marker.Label" />
                        }
                        @if (SimulationInfoHoverMarkers.Count > SimulationInfoMaxHoverLabels)
                        {
                            <SvgText X="@(SimulationInfoHoverPanelX + 16)" Y="@(SimulationInfoHoverPanelY + 20 + SimulationInfoMaxHoverLabels * 15)" Anchor="start" Label="@SimulationInfoMoreHoverLabel" />
                        }
                    }
                    @foreach (var zone in SimulationInfoHoverZones)
                    {
                        <rect x="@zone.X" y="28" width="@zone.Width" height="192" fill="transparent" class="chart-hover-zone"
                              @onmouseover="() => SimulationInfoHoverIndex = zone.Index"
                              @onfocus="() => SimulationInfoHoverIndex = zone.Index" />
                    }
                </svg>
                <div class="inline-legend">
                    @foreach (var row in SelectedSimulationInfoChartRows)
                    {
                        <span><i style="background:@SimulationInfoColor(row.Key)"></i>@row.Metric</span>
                    }
                    @if (SelectedSimulationInfoChartRows.Any(row => row.ReferenceValue is not null))
                    {
                        <span><i style="background:#172026"></i>Reference dashed</span>
                    }
                </div>
            </aside>
            }
        </div>
    </ToolPanel>
