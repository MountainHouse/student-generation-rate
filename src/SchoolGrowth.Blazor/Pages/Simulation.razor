                                <td>@comparison.GridError.ToString("+#,##0;-#,##0;0")</td>
                                <td>@comparison.GridAbsolutePercentageError.ToString("P1")</td>
                                <td>@comparison.GridLevelMeanAbsolutePercentageError.ToString("P1")</td>
                                <td>@comparison.ActualGradeTotal.ToString("N0")</td>
                                <td>@comparison.ModeledGradeTotal.ToString("N0")</td>
