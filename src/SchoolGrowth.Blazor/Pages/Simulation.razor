    private static string ChartBandPoints(ValidationChartLine series, int sigmaMultiplier, Func<double, double> ySelector)
    {
        var lowValues = sigmaMultiplier == 2 ? series.TwoSigmaLowValues : series.OneSigmaLowValues;
        var highValues = sigmaMultiplier == 2 ? series.TwoSigmaHighValues : series.OneSigmaHighValues;
        if (lowValues is null || highValues is null || series.Values.Count < 2)
        {
            return "";
        }

        var points = series.Values
            .Select((_, index) => new
            {
                Index = index,
                Low = lowValues.ElementAtOrDefault(index),
                High = highValues.ElementAtOrDefault(index)
            })
            .Where(item => item.Low.HasValue && item.High.HasValue)
            .ToList();
        if (points.Count < 2)
        {
            return "";
        }

        double xForIndex(int index) => series.Values.Count == 1 ? 60 : 60 + (index * 800.0 / (series.Values.Count - 1));
        var highPoints = points.Select(item => $"{xForIndex(item.Index):0.##},{ySelector(item.High!.Value):0.##}");
        var lowPoints = points
            .AsEnumerable()
            .Reverse()
            .Select(item => $"{xForIndex(item.Index):0.##},{ySelector(item.Low!.Value):0.##}");

        return string.Join(" ", highPoints.Concat(lowPoints));
    }

