    private bool IsToolActive(string id) => ActiveToolIds.Contains(id);

    private bool IsToolCollapsed(string id) => CollapsedToolIds.Contains(id);

    private bool IsResultToolId(string id) =>
        id.StartsWith(ToolChartPrefix, StringComparison.OrdinalIgnoreCase)
        || ResultToolIds.Contains(id);

    private MonteCarloToolDefinition? ToolDefinitionForId(string id)
    {
        var chart = ChartTools.FirstOrDefault(tool => tool.Id.Equals(id, StringComparison.OrdinalIgnoreCase));
        if (chart is not null)
        {
            return new MonteCarloToolDefinition(chart.Id, chart.Title);
        }

        return ToolDefinitions.FirstOrDefault(tool => tool.Id.Equals(id, StringComparison.OrdinalIgnoreCase));
    }

    private string ToolStyle(string id) => $"order: {Math.Max(0, ActiveToolIds.IndexOf(id))};";

    private bool CanMoveToolUp(string id) => ActiveToolIds.IndexOf(id) > 0;

    private bool CanMoveToolDown(string id)
    {
        var index = ActiveToolIds.IndexOf(id);
        return index >= 0 && index < ActiveToolIds.Count - 1;
    }

    private void ToggleTool(string id)
    {
        if (!CollapsedToolIds.Add(id))
        {
            CollapsedToolIds.Remove(id);
        }
    }

    private void MoveToolUp(string id)
    {
        var index = ActiveToolIds.IndexOf(id);
        if (index <= 0) return;

        (ActiveToolIds[index - 1], ActiveToolIds[index]) = (ActiveToolIds[index], ActiveToolIds[index - 1]);
    }

    private void MoveToolDown(string id)
    {
        var index = ActiveToolIds.IndexOf(id);
        if (index < 0 || index >= ActiveToolIds.Count - 1) return;

        (ActiveToolIds[index + 1], ActiveToolIds[index]) = (ActiveToolIds[index], ActiveToolIds[index + 1]);
    }

    private void RemoveTool(string id)
    {
        ActiveToolIds.Remove(id);
        CollapsedToolIds.Remove(id);
        if (id.StartsWith(ToolChartPrefix, StringComparison.OrdinalIgnoreCase))
        {
            ChartTools.RemoveAll(tool => tool.Id.Equals(id, StringComparison.OrdinalIgnoreCase));
        }
        if (string.IsNullOrWhiteSpace(NewToolId))
        {
            NewToolId = id.StartsWith(ToolChartPrefix, StringComparison.OrdinalIgnoreCase)
                ? ToolChartPrototype
                : id;
        }
    }

    private void AddSelectedTool()
    {
        var id = !string.IsNullOrWhiteSpace(NewToolId) && InactiveTools.Any(tool => tool.Id == NewToolId)
            ? NewToolId
            : InactiveTools.FirstOrDefault()?.Id;
        if (string.IsNullOrWhiteSpace(id)) return;

        if (id.Equals(ToolChartPrototype, StringComparison.OrdinalIgnoreCase))
        {
            CreateChartTool();
            NewToolId = "";
            return;
        }

        if (ActiveToolIds.Contains(id)) return;

        ActiveToolIds.Add(id);
        CollapsedToolIds.Remove(id);
        NewToolId = "";
    }

    private async Task AddToolFromSelectionAsync(ChangeEventArgs args)
    {
        var id = args.Value?.ToString();
        NewToolId = "";
        if (string.IsNullOrWhiteSpace(id)) return;

        if (id.Equals(ToolChartPrototype, StringComparison.OrdinalIgnoreCase))
        {
            var chart = CreateChartTool();
            ToolsPopupOpen = false;
            await InvokeAsync(StateHasChanged);
            await ScrollToToolAsync(chart.Id);
            return;
        }

        if (ActiveToolIds.Contains(id)) return;

        ActiveToolIds.Add(id);
        CollapsedToolIds.Remove(id);
        ToolsPopupOpen = false;
        await InvokeAsync(StateHasChanged);
        await ScrollToToolAsync(id);
    }

    private ChartToolState CreateChartTool(SavedChartTool? saved = null, bool activate = true)
    {
        var id = saved?.Id;
        if (string.IsNullOrWhiteSpace(id) || ChartTools.Any(tool => tool.Id.Equals(id, StringComparison.OrdinalIgnoreCase)))
        {
            var number = NextChartToolNumber++;
            id = $"{ToolChartPrefix}{number}";
            saved ??= new SavedChartTool(id, $"Chart {number}", "students", AllNeighborhood, AllDensity, "Total", "value", []);
        }

        var title = string.IsNullOrWhiteSpace(saved?.Title) ? $"Chart {NextChartToolNumber}" : saved!.Title;
        var chart = new ChartToolState(id, title)
        {
            Measure = string.IsNullOrWhiteSpace(saved?.Measure) ? "students" : saved!.Measure,
            Neighborhood = string.IsNullOrWhiteSpace(saved?.Neighborhood) ? AllNeighborhood : saved!.Neighborhood,
            Density = string.IsNullOrWhiteSpace(saved?.Density) ? AllDensity : saved!.Density,
            Breakdown = string.IsNullOrWhiteSpace(saved?.Breakdown) ? "Total" : saved!.Breakdown,
            ValueMode = string.IsNullOrWhiteSpace(saved?.ValueMode) ? "value" : saved!.ValueMode
        };

        if (saved?.PinnedSelections is not null)
        {
            foreach (var pin in saved.PinnedSelections)
            {
                chart.PinnedSelections.Add(new ChartPinnedSelection(
                    pin.Id,
                    new ChartSelection(pin.Measure, pin.Neighborhood, pin.Density, pin.Breakdown, pin.ValueMode)));
            }
        }

        chart.NextPinnedSelectionId = Math.Max(
            1,
            chart.PinnedSelections.Select(selection => selection.Id).DefaultIfEmpty(0).Max() + 1);
        ChartTools.Add(chart);
        if (activate)
        {
            ActiveToolIds.Add(chart.Id);
            CollapsedToolIds.Remove(chart.Id);
        }
        UpdateNextChartToolNumber();
        if (Result is not null)
        {
            NormalizeChartSelections(chart, resetNeighborhood: false, resetBreakdown: false, resetValueMode: false);
        }
        return chart;
    }

    private void UpdateNextChartToolNumber()
    {
        var max = ChartTools
            .Select(tool => tool.Id.StartsWith(ToolChartPrefix, StringComparison.OrdinalIgnoreCase)
                && int.TryParse(tool.Id[ToolChartPrefix.Length..], out var number)
                    ? number
                    : 0)
            .DefaultIfEmpty(0)
            .Max();
        NextChartToolNumber = Math.Max(NextChartToolNumber, max + 1);
    }

