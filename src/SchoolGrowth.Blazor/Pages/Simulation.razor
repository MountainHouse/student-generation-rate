                                <td>@comparison.GradeError.ToString("+#,##0;-#,##0;0")</td>
                                <td>@comparison.GradeAbsolutePercentageError.ToString("P1")</td>
                                <td>@comparison.GradeLevelMeanAbsolutePercentageError.ToString("P1")</td>
                                <td>@comparison.HighSchoolActualTotal.ToString("N0")</td>
