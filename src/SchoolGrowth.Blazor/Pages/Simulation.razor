    protected override async Task OnInitializedAsync()
    {
        try
        {
            var homes = await Http.GetStringAsync("data/homes.csv");
            var grid = await Http.GetStringAsync("data/grid.csv");
            var grade = await Http.GetStringAsync("data/grade.csv");
            var schools = await Http.GetStringAsync("data/schools.csv");
            Data = EnrollmentData.LoadFromCsvText(homes, grid, grade, schools);
            Model = new MonteCarloEnrollmentModel(Data);
            await LoadPresetsAsync();
            StartYear = Math.Max(MinStartYear, LatestReferenceYear - 5);
            EndYear = LatestReferenceYear;
            SelectedComparisonYear = EndYear;
            await LoadSavedLayoutAsync();
            await DetectServerApiAsync();
            _ = RunValidationAsync();
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Data is not null)
        {
            if (ValidationHoverRenderPending || ChartHoverRenderPending)
            {
                ValidationHoverRenderPending = false;
                ChartHoverRenderPending = false;
                return;
            }

            if (TrackCustomPreset())
            {
                await InvokeAsync(StateHasChanged);
            }
            if (SavedLayoutLoaded)
            {
                await SaveLayoutAsync();
            }
            await Js.InvokeVoidAsync("schoolGrowthMasonry.attach", ".settings-stack");
            await Js.InvokeVoidAsync("schoolGrowthTables.attach", ".table-wrap");
            await Js.InvokeVoidAsync("schoolGrowthTools.attachDraggable", ".tool-nav-float");
            await Js.InvokeVoidAsync("schoolGrowthTools.setOpen", ".tool-nav-float", ToolsPopupOpen);
            if (Result is not null && IsToolActive(ToolValidationSummary))
            {
                ValidationHoverReference ??= DotNetObjectReference.Create(this);
                await Js.InvokeVoidAsync(
                    "schoolGrowthValidationChart.attach",
                    ValidationChartSvg,
                    ValidationHoverReference,
                    Result.Comparisons.Count,
                    ToolValidationSummary);
            }
            if (Result is not null)
            {
                ValidationHoverReference ??= DotNetObjectReference.Create(this);
                foreach (var chart in ChartTools.Where(chart => IsToolActive(chart.Id) && !IsToolCollapsed(chart.Id)))
                {
                    await Js.InvokeVoidAsync(
                        "schoolGrowthValidationChart.attachById",
                        ChartSvgElementId(chart),
                        ValidationHoverReference,
                        Result.Comparisons.Count,
                        chart.Id);
                }
            }
        }
    }

    private async Task LoadPresetsAsync()
    {
        try
        {
            var presets = await Http.GetFromJsonAsync<IReadOnlyList<MonteCarloParameterPreset>>("data/simulation-presets.json");
            if (presets is not null && presets.Count > 0)
            {
                ParameterPresets = presets;
                SelectedPresetName = presets.FirstOrDefault(preset => preset.Name.Equals("default", StringComparison.OrdinalIgnoreCase))?.Name
                    ?? presets[0].Name;
                ApplyParameters(SelectedPreset?.Parameters ?? presets[0].Parameters);
            }
        }
        catch
        {
            SelectedPresetName = "default";
            ApplyParameters(DefaultParameters);
        }
