    private static string ValidationColorForIndex(int index)
    {
        string[] colors =
        [
            "#b45309",
            "#0f766e",
            "#2563eb",
            "#7c3aed",
            "#be123c",
            "#15803d",
            "#c2410c",
            "#475569"
        ];

        return colors[Math.Abs(index) % colors.Length];
    }

    private ValidationChartLine BuildModeledChartLine(
        string label,
        string color,
        IReadOnlyList<double?> values,
        IReadOnlyList<double?> standardDeviations,
        Func<double, string> formatter)
    {
        if (!standardDeviations.Any(value => value is > 0))
        {
            return new(label, color, values, formatter, "");
        }

        var oneSigmaLow = SigmaBand(values, standardDeviations, -1);
        var oneSigmaHigh = SigmaBand(values, standardDeviations, 1);
        var twoSigmaLow = SigmaBand(values, standardDeviations, -2);
        var twoSigmaHigh = SigmaBand(values, standardDeviations, 2);

        return new(
            label,
            color,
            values,
            formatter,
            "",
            StandardDeviations: standardDeviations,
            Runs: Result?.Parameters.Runs ?? Runs,
            OneSigmaLowValues: oneSigmaLow,
            OneSigmaHighValues: oneSigmaHigh,
            TwoSigmaLowValues: twoSigmaLow,
            TwoSigmaHighValues: twoSigmaHigh);
    }

    private static IReadOnlyList<double?> SigmaBand(IReadOnlyList<double?> values, IReadOnlyList<double?> standardDeviations, int multiplier)
    {
        return values.Select((value, index) =>
        {
            var deviation = standardDeviations.ElementAtOrDefault(index);
            return value.HasValue && deviation.HasValue
                ? value.Value + deviation.Value * multiplier
                : (double?)null;
        }).ToList();
    }

    private void PinValidationChartSelection()
    {
        if (ValidationPinnedSelections.Any(selection => selection.Key.Equals(CurrentValidationSelectionKey, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        var cache = CurrentValidationChart;
        var color = ValidationColorForIndex(ValidationPinnedSelections.Count);
        var series = cache.Series
            .Select(line => line with { Color = color })
            .ToList();
        ValidationPinnedSelections.Add(new ValidationPinnedSelection(
            NextValidationPinnedSelectionId++,
            CurrentValidationSelectionKey,
            ValidationChartSelectionLabel,
            series));
        InvalidateValidationChartCache();
    }

    private void RemoveValidationChartSelection(int id)
    {
        ValidationPinnedSelections.RemoveAll(selection => selection.Id == id);
        InvalidateValidationChartCache();
    }

    private IReadOnlyList<double> ValidationChartNumbers => ValidationChartSeries
        .SelectMany(series => series.Values
            .Concat(series.OneSigmaLowValues ?? [])
            .Concat(series.OneSigmaHighValues ?? [])
            .Concat(series.TwoSigmaLowValues ?? [])
            .Concat(series.TwoSigmaHighValues ?? []))
        .Where(value => value.HasValue)
        .Select(value => value!.Value)
        .ToList();

    private double ValidationChartMax
    {
        get
        {
            var values = ValidationChartNumbers;
            if (values.Count == 0)
            {
                return 1;
            }

            var max = values.Max();
            var min = values.Min();
            if (min < 0)
            {
                return ChartAxis.NiceMaximum(Math.Max(Math.Abs(min), Math.Abs(max)) * 1.08);
            }

            return ChartAxis.NiceMaximum(Math.Max(1, max * 1.08));
        }
    }

    private double ValidationChartMin => ValidationChartNumbers.DefaultIfEmpty(0).Min() < 0 ? -ValidationChartMax : 0;

    private double ValidationChartSpan => Math.Max(1, ValidationChartMax - ValidationChartMin);

    private ValidationChartCache CurrentValidationChart
    {
        get
        {
            var key = $"{ValidationResultVersion}|{CurrentValidationSelectionKey}";
            if (ValidationChartCacheValue is not null && ValidationChartCacheKey == key)
            {
                return ValidationChartCacheValue;
            }

            var modeledBase = ValidationModeledBaseValues;
            var referenceBase = ValidationReferenceBaseValues;
            var modeledValues = TransformValidationValues(modeledBase, reference: false);
            var referenceValues = TransformValidationValues(referenceBase, reference: true);
            var modeledStdDevs = TransformValidationStandardDeviations(ValidationModeledStandardDeviationBaseValues, modeledBase);
            var absoluteErrors = referenceBase
                .Zip(modeledBase, (reference, modeled) => reference.HasValue && modeled.HasValue ? Math.Abs(modeled.Value - reference.Value) : (double?)null)
                .ToList();
            var percentErrors = referenceBase
                .Zip(modeledBase, (reference, modeled) => reference is > 0 && modeled.HasValue ? Math.Abs(modeled.Value - reference.Value) / reference.Value : (double?)null)
                .ToList();
            var hasReference = referenceBase.Any(value => value.HasValue);
            var color = ValidationColorForIndex(ValidationPinnedSelections.Count);
            var series = EffectiveValidationValueMode switch
            {
                "absolute-error" => new List<ValidationChartLine> { new("Absolute error", color, absoluteErrors, FormatCount, "") },
                "percent-error" => new List<ValidationChartLine> { new("Percentage error", color, percentErrors, FormatPercent, "") },
                _ => hasReference
                    ?
                    [
                        new("Reference", color, referenceValues, ValidationFormatter, "7 5"),
                        BuildModeledChartLine(ValidationModeledSeriesLabel, color, modeledValues, modeledStdDevs, ValidationFormatter)
                    ]
                    :
                    [
                        BuildModeledChartLine(ValidationModeledSeriesLabel, color, modeledValues, modeledStdDevs, ValidationFormatter)
                    ]
            };
            var numbers = series
                .SelectMany(item => item.Values
                    .Concat(item.OneSigmaLowValues ?? [])
                    .Concat(item.OneSigmaHighValues ?? [])
                    .Concat(item.TwoSigmaLowValues ?? [])
                    .Concat(item.TwoSigmaHighValues ?? []))
                .Where(value => value.HasValue)
                .Select(value => value!.Value)
                .ToList();
            var max = 1.0;
            var min = 0.0;
            if (numbers.Count > 0)
            {
                var rawMax = numbers.Max();
                var rawMin = numbers.Min();
                if (rawMin < 0)
                {
                    max = ChartAxis.NiceMaximum(Math.Max(Math.Abs(rawMin), Math.Abs(rawMax)) * 1.08);
                    min = -max;
                }
                else
                {
                    max = ChartAxis.NiceMaximum(Math.Max(1, rawMax * 1.08));
                }
            }

            ValidationChartCacheValue = new ValidationChartCache(
                modeledValues,
                referenceValues,
                absoluteErrors,
                percentErrors,
                series,
                numbers,
                max,
                min,
                Math.Max(1, max - min));
            ValidationChartCacheKey = key;
            return ValidationChartCacheValue;
        }
    }

    private double? ValidationModeledBaseValue(MonteCarloYearComparison comparison)
    {
        var segment = SegmentStatsForYear(comparison.Year);

        return ValidationMeasure switch
        {
            "homes" => HomesValue(comparison.Year, EffectiveValidationNeighborhood, EffectiveValidationDensity, EffectiveValidationBreakdown),
            "cohort" => CohortValue(comparison, modeled: true),
            "generation" => StudentGenerationValue(comparison, modeled: true),
            "family" => FamilyValue(segment),
            "turnover" => TurnoverValue(segment),
            _ => StudentValue(comparison, modeled: true)
        };
    }

    private double? ValidationReferenceBaseValue(MonteCarloYearComparison comparison)
    {
        return ValidationMeasure switch
        {
            "cohort" => CohortValue(comparison, modeled: false),
            "generation" => StudentGenerationReferenceValue(comparison),
            "students" => StudentValue(comparison, modeled: false),
            _ => null
        };
    }

    private double? ValidationModeledStandardDeviationBaseValue(MonteCarloYearComparison comparison)
    {
        return ValidationMeasure switch
        {
            "cohort" => CohortStandardDeviation(comparison),
            "students" => StudentStandardDeviation(comparison),
            _ => null
        };
    }

    private double? StudentValue(MonteCarloYearComparison comparison, bool modeled)
    {
        return StudentValue(comparison, modeled, EffectiveValidationBreakdown);
    }

    private double? StudentValue(MonteCarloYearComparison comparison, bool modeled, string breakdown)
    {
        var neighborhood = EffectiveValidationNeighborhood;
        var density = EffectiveValidationDensity;

        if (!modeled && !HasReferenceData(comparison))
        {
            return null;
        }

        if (!modeled && !density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        if (!neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase) || !density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
        {
            if (!modeled)
            {
                return breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
                    && neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase) == false
                    ? comparison.ActualGridTotals.GetValueOrDefault(neighborhood)
                    : null;
            }

            return SegmentStudentValue(comparison.Year, breakdown);
        }

        return modeled
            ? ModeledStudentBreakdown(comparison, breakdown)
            : ReferenceStudentBreakdown(comparison, breakdown);
    }

    private double? StudentGenerationValue(MonteCarloYearComparison comparison, bool modeled)
    {
        var students = StudentValueForGeneration(comparison, modeled);
        var homes = HomesValue(comparison.Year, EffectiveValidationNeighborhood, EffectiveValidationDensity, "Total");
        return students.HasValue && homes is > 0 ? students.Value / homes.Value : null;
    }

    private double? StudentGenerationReferenceValue(MonteCarloYearComparison comparison)
    {
        var students = StudentValueForGeneration(comparison, modeled: false);
        var homes = HomesValue(comparison.Year, EffectiveValidationNeighborhood, EffectiveValidationDensity, "Total");
        return students.HasValue && homes is > 0 ? students.Value / homes.Value : null;
    }

    private double? CohortValue(MonteCarloYearComparison comparison, bool modeled)
    {
        var cohort = CohortForLabel(EffectiveValidationBreakdown);
        var grade = cohort is null ? null : GradeForCohort(cohort, comparison.Year);
        if (grade is null)
        {
            return null;
        }

        if (!modeled && !HasReferenceData(comparison))
        {
            return null;
        }

        if (!modeled
            && (!EffectiveValidationDensity.Equals(AllDensity, StringComparison.OrdinalIgnoreCase)
                || !EffectiveValidationNeighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)))
        {
            return null;
        }

        if (modeled
            && (!EffectiveValidationNeighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                || !EffectiveValidationDensity.Equals(AllDensity, StringComparison.OrdinalIgnoreCase)))
        {
            return SegmentStatsForYear(comparison.Year).Grades.GetValueOrDefault(grade);
        }

        return modeled
            ? comparison.ModeledGrades.GetValueOrDefault(grade)
            : comparison.AdjustedActualGrades.GetValueOrDefault(grade);
    }

    private double? CohortStandardDeviation(MonteCarloYearComparison comparison)
    {
        var cohort = CohortForLabel(EffectiveValidationBreakdown);
        var grade = cohort is null ? null : GradeForCohort(cohort, comparison.Year);
        if (grade is null)
        {
            return null;
        }

        if (!EffectiveValidationNeighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
            || !EffectiveValidationDensity.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
        {
            return EffectiveValidationDensity.Equals(AllDensity, StringComparison.OrdinalIgnoreCase)
                && !EffectiveValidationNeighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                ? comparison.ModeledGridGradeStandardDeviations.GetValueOrDefault(EffectiveValidationNeighborhood)?.GetValueOrDefault(grade)
                : null;
        }

        return comparison.ModeledGradeStandardDeviations.GetValueOrDefault(grade);
    }

    private double? StudentStandardDeviation(MonteCarloYearComparison comparison)
    {
        if (!EffectiveValidationDensity.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        if (!EffectiveValidationNeighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase))
        {
            return EffectiveValidationBreakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
                ? comparison.ModeledGridTotalStandardDeviations.GetValueOrDefault(EffectiveValidationNeighborhood)
                : comparison.ModeledGridGradeStandardDeviations.GetValueOrDefault(EffectiveValidationNeighborhood)?.GetValueOrDefault(EffectiveValidationBreakdown);
        }

        return EffectiveValidationBreakdown switch
        {
            "Total" or "K-12" => comparison.ModeledGradeTotalStandardDeviation,
            "HS" => comparison.HighSchoolModeledTotalStandardDeviation,
            "K-8" => null,
            _ => comparison.ModeledGradeStandardDeviations.GetValueOrDefault(EffectiveValidationBreakdown)
        };
    }

    private double? StudentValueForGeneration(MonteCarloYearComparison comparison, bool modeled)
    {
        var breakdown = EffectiveValidationBreakdown;

        if ((!EffectiveValidationNeighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                || !EffectiveValidationDensity.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
            && !breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
            && !modeled)
        {
            return null;
        }

        return StudentValue(comparison, modeled, breakdown);
    }

    private IReadOnlyList<double?> TransformValidationValues(IReadOnlyList<double?> values, bool reference)
    {
        return EffectiveValidationValueMode switch
        {
            "share" => Result?.Comparisons.Select((comparison, index) =>
            {
                var value = values.ElementAtOrDefault(index);
                var denominator = ValidationShareDenominator(comparison, reference);
                return value.HasValue && denominator is > 0 ? value.Value / denominator.Value : (double?)null;
            }).ToList() ?? [],
            "previous-change" => TransformAgainstPrevious(values, percent: false),
            "previous-percent" => TransformAgainstPrevious(values, percent: true),
            "start-change" => TransformAgainstStart(values, percent: false),
            "start-percent" => TransformAgainstStart(values, percent: true),
            _ => values
        };
    }

    private IReadOnlyList<double?> TransformValidationStandardDeviations(
        IReadOnlyList<double?> standardDeviations,
        IReadOnlyList<double?> modeledBaseValues)
    {
        return EffectiveValidationValueMode.Equals("value", StringComparison.OrdinalIgnoreCase)
            ? standardDeviations
            : modeledBaseValues.Select(_ => (double?)null).ToList();
    }

    private static IReadOnlyList<double?> TransformAgainstPrevious(IReadOnlyList<double?> values, bool percent)
    {
        return values.Select((value, index) =>
        {
            if (index == 0 || !value.HasValue || !values[index - 1].HasValue)
            {
                return (double?)null;
            }

            var previous = values[index - 1]!.Value;
            var change = value.Value - previous;
            return percent
                ? previous != 0 ? change / previous : (double?)null
                : change;
        }).ToList();
    }

    private static IReadOnlyList<double?> TransformAgainstStart(IReadOnlyList<double?> values, bool percent)
    {
        var start = values.FirstOrDefault(value => value.HasValue);
        return values.Select(value =>
        {
            if (!value.HasValue || !start.HasValue)
            {
                return (double?)null;
            }

            var change = value.Value - start.Value;
            return percent
                ? start.Value != 0 ? change / start.Value : (double?)null
                : change;
        }).ToList();
    }

    private double? ValidationShareDenominator(MonteCarloYearComparison comparison, bool reference)
    {
        return ValidationMeasure switch
        {
            "students" or "cohort" => EffectiveValidationNeighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                    && EffectiveValidationDensity.Equals(AllDensity, StringComparison.OrdinalIgnoreCase)
                ? StudentValue(comparison, modeled: !reference, "Total")
                : EffectiveValidationBreakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
                    ? StudentValue(comparison, modeled: !reference, "Total")
                    : StudentValue(comparison, modeled: true, "Total"),
            "homes" => HomesValue(comparison.Year, EffectiveValidationNeighborhood, EffectiveValidationDensity, "Total"),
            "family" => SegmentStatsForYear(comparison.Year).TotalHomes,
            _ => null
        };
    }

    private MonteCarloSimulationYearInfo? SimulationInfoForYear(int year)
    {
        return Result?.SimulationInfo.FirstOrDefault(item => item.Year == year);
    }

    private double ModeledStudentBreakdown(MonteCarloYearComparison comparison, string breakdown)
    {
        return breakdown switch
        {
            "Total" or "K-12" => ModeledK12Total(comparison),
            "K-8" => SumGrades(comparison.ModeledGrades, K8Grades),
            "HS" => comparison.HighSchoolModeledTotal,
            _ => comparison.ModeledGrades.GetValueOrDefault(breakdown)
        };
    }

    private double? ReferenceStudentBreakdown(MonteCarloYearComparison comparison, string breakdown)
    {
        if (!HasReferenceData(comparison))
        {
            return null;
        }

        return breakdown switch
        {
            "Total" or "K-12" => ReferenceK12Total(comparison),
            "K-8" => SumGrades(comparison.AdjustedActualGrades, K8Grades),
            "HS" => comparison.HighSchoolActualTotal,
            _ => comparison.AdjustedActualGrades.GetValueOrDefault(breakdown)
        };
    }

    private static double ModeledK12Total(MonteCarloYearComparison comparison)
    {
        return SumGrades(comparison.ModeledGrades, K8Grades.Concat(HighSchoolGrades).Append("Sp. Ed."));
    }

    private static double ReferenceK12Total(MonteCarloYearComparison comparison)
    {
        return SumGrades(comparison.AdjustedActualGrades, K8Grades.Concat(HighSchoolGrades).Append("Sp. Ed."));
    }

    private SegmentStats SegmentStatsForYear(int year)
    {
        var key = $"{ValidationResultVersion}|{year}|{EffectiveValidationNeighborhood}|{EffectiveValidationDensity}";
        if (ValidationSegmentStatsCache.TryGetValue(key, out var cached))
        {
            return cached;
        }

        var segments = SimulationInfoForYear(year)?.Segments ?? [];
        var selected = segments
            .Where(segment => EffectiveValidationNeighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                || segment.Grid.Equals(EffectiveValidationNeighborhood, StringComparison.OrdinalIgnoreCase))
            .Where(segment => DensityMatchesSelection(segment.Density, EffectiveValidationDensity))
            .ToList();

        var grades = GradeOrder.ToDictionary(
            grade => grade,
            grade => selected.Sum(segment => segment.Grades.GetValueOrDefault(grade)),
            StringComparer.OrdinalIgnoreCase);
        var turnoverEvents = selected.Sum(segment => segment.TurnoverEvents);

        var result = new SegmentStats(
            selected.Sum(segment => segment.TotalHomes),
            grades,
            selected.Sum(segment => segment.FamiliesWithZeroChildren),
            selected.Sum(segment => segment.FamiliesWithOneChild),
            selected.Sum(segment => segment.FamiliesWithTwoChildren),
            selected.Sum(segment => segment.FamiliesWithThreeChildren),
            selected.Sum(segment => segment.FamiliesWithFourPlusChildren),
            turnoverEvents,
            turnoverEvents > 0
                ? selected.Sum(segment => segment.AverageLongevityBeforeTurnover * segment.TurnoverEvents) / turnoverEvents
                : 0);
        ValidationSegmentStatsCache[key] = result;
        return result;
    }

    private double SegmentStudentValue(int year, string breakdown)
    {
        var grades = SegmentStatsForYear(year).Grades;
        return breakdown switch
        {
            "Total" or "K-12" => SumGrades(grades, K8Grades.Concat(HighSchoolGrades).Append("Sp. Ed.")),
            "K-8" => SumGrades(grades, K8Grades),
            "HS" => SumGrades(grades, HighSchoolGrades),
            _ => grades.GetValueOrDefault(breakdown)
        };
    }

    private double? HomesValue(int year, string neighborhood, string density, string breakdown)
    {
        var stats = SegmentStatsForYear(year);
        return breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
            ? stats.TotalHomes
            : HomesValueForDensityBreakdown(year, neighborhood, breakdown);
    }

    private double? HomesValueForDensityBreakdown(int year, string neighborhood, string breakdown)
    {
        var segments = SimulationInfoForYear(year)?.Segments ?? [];
        return segments
            .Where(segment => neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                || segment.Grid.Equals(neighborhood, StringComparison.OrdinalIgnoreCase))
            .Where(segment => DensityMatchesSelection(segment.Density, breakdown))
            .Sum(segment => segment.TotalHomes);
    }

    private double? FamilyValue(SegmentStats year)
    {
        return EffectiveValidationBreakdown switch
        {
            "0 kids" => year.FamiliesWithZeroChildren,
            "1 kid" => year.FamiliesWithOneChild,
            "2 kids" => year.FamiliesWithTwoChildren,
            "3 kids" => year.FamiliesWithThreeChildren,
            "4+ kids" => year.FamiliesWithFourPlusChildren,
            _ => null
        };
    }

    private double? TurnoverValue(SegmentStats year)
    {
        return EffectiveValidationBreakdown switch
        {
            "Turnover factor" => year.TotalHomes > 0 ? year.TurnoverEvents / year.TotalHomes : 0,
            "Average longevity" => year.AverageLongevityBeforeTurnover,
            _ => year.TurnoverEvents
        };
    }

    private static bool DensityMatchesSelection(string density, string selection)
    {
        return selection switch
        {
            AllDensity => true,
            "Low/medium" => density is "Low" or "Medium" or "Other/existing",
            "Medium-high/high" => density is "Medium-high" or "High",
            _ => density.Equals(selection, StringComparison.OrdinalIgnoreCase)
        };
    }

    private static string DensityBreakdownKey(string breakdown)
    {
        return breakdown switch
        {
            "Low" => "low",
            "Medium" => "medium",
            "Medium-high" => "medium-high",
            "High" => "high",
            "Other/existing" => "other",
            "Low/medium" => "low-medium",
            "Medium-high/high" => "medium-high-high",
            _ => "all"
        };
    }

    private static double SumGrades(IReadOnlyDictionary<string, double> grades, IEnumerable<string> selectedGrades)
    {
        return selectedGrades.Sum(grade => grades.GetValueOrDefault(grade));
    }

    private void OnValidationMeasureChanged(ChangeEventArgs args)
    {
        ValidationMeasure = args.Value?.ToString() ?? "students";
        NormalizeValidationChartSelections(resetNeighborhood: true, resetBreakdown: true, resetValueMode: true);
    }

    private void OnValidationNeighborhoodChanged(ChangeEventArgs args)
    {
        ValidationNeighborhood = args.Value?.ToString() ?? AllNeighborhood;
        NormalizeValidationChartSelections(resetBreakdown: false, resetValueMode: true);
    }

    private void OnValidationDensityChanged(ChangeEventArgs args)
    {
        ValidationDensity = args.Value?.ToString() ?? AllDensity;
        NormalizeValidationChartSelections(resetBreakdown: false, resetValueMode: true);
    }

    private void OnValidationBreakdownChanged(ChangeEventArgs args)
    {
        ValidationBreakdown = args.Value?.ToString() ?? "Total";
        NormalizeValidationChartSelections(resetValueMode: true);
    }

    private void OnValidationValueModeChanged(ChangeEventArgs args)
    {
        ValidationValueMode = args.Value?.ToString() ?? "value";
        NormalizeValidationChartSelections();
    }

    private void NormalizeValidationChartSelections(
        bool resetNeighborhood = false,
        bool resetBreakdown = false,
        bool resetValueMode = false)
    {
        if (!new[] { "students", "cohort", "homes", "generation", "family", "turnover" }.Contains(ValidationMeasure))
        {
            ValidationMeasure = "students";
        }

        if (resetNeighborhood || !ValidationNeighborhoodOptions.Contains(ValidationNeighborhood))
        {
            ValidationNeighborhood = ValidationNeighborhoodOptions.FirstOrDefault() ?? AllNeighborhood;
        }

        if (!ValidationDensityOptions.Contains(ValidationDensity))
        {
            ValidationDensity = AllDensity;
        }

        if (resetBreakdown || !ValidationBreakdownOptions.Contains(ValidationBreakdown))
        {
            ValidationBreakdown = ValidationBreakdownOptions.FirstOrDefault() ?? "Total";
        }

        if (resetValueMode || !ValidationValueModeOptions.Any(option => option.Key.Equals(ValidationValueMode, StringComparison.OrdinalIgnoreCase)))
        {
            ValidationValueMode = "value";
        }

        TotalChartHoverIndex = null;
        InvalidateValidationChartCache();
    }

    private void InvalidateValidationChartCache()
    {
        ValidationChartCacheValue = null;
        ValidationChartCacheKey = null;
        ValidationSegmentStatsCache.Clear();
    }

    private IReadOnlyList<string> ChartNeighborhoodOptions(ChartToolState chart) => chart.Measure is "family" or "turnover"
        ? [AllNeighborhood, .. Result?.SimulationInfo.FirstOrDefault()?.Segments
            .Select(segment => segment.Grid)
            .Where(grid => !ExcludedValidationGrids.Contains(grid))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(grid => grid, StringComparer.OrdinalIgnoreCase)
            .ToList() ?? []]
        : [AllNeighborhood, .. Result?.Comparisons.FirstOrDefault()?.ModeledGridTotals.Keys
            .Where(grid => !ExcludedValidationGrids.Contains(grid))
            .Order()
            .ToList() ?? []];

    private IReadOnlyList<string> ChartBreakdownOptions(ChartToolState chart) => chart.Measure switch
    {
        "homes" => ["Total"],
        "cohort" => CohortBreakdownOptions,
        "generation" => ["K-12", "K-8", "HS"],
        "family" => ["0 kids", "1 kid", "2 kids", "3 kids", "4+ kids"],
        "turnover" => ["Turnover events", "Turnover factor", "Average longevity"],
        _ => ["Total", "K-8", "HS", .. VisibleGradeOrder]
    };

    private IReadOnlyList<ValidationValueModeOption> ChartValueModeOptions(ChartToolState chart)
    {
        var selection = new ChartSelection(
            chart.Measure is "students" or "cohort" or "homes" or "generation" or "family" or "turnover" ? chart.Measure : "students",
            EffectiveChartNeighborhood(chart),
            EffectiveChartDensity(chart),
            EffectiveChartBreakdown(chart),
            chart.ValueMode);
        return ChartValueModeOptions(selection);
    }

    private IReadOnlyList<ValidationValueModeOption> ChartValueModeOptions(ChartSelection selection)
    {
        var options = new List<ValidationValueModeOption>
        {
            new("value", selection.Measure is "generation" ? "Value" : "Count")
        };

        if (ChartSupportsShare(selection))
        {
            options.Add(new("share", "Percent"));
        }

        options.AddRange(
        [
            new("previous-change", "Change previous"),
            new("previous-percent", "Change previous %"),
            new("start-change", "Change cumulative"),
            new("start-percent", "Change cumulative %")
        ]);

        if (ChartHasReference(selection))
        {
            options.Add(new("absolute-error", "Absolute error"));
            options.Add(new("percent-error", "Percentage error"));
        }

        return options;
    }

    private string EffectiveChartNeighborhood(ChartToolState chart)
    {
        var options = ChartNeighborhoodOptions(chart);
        return options.Contains(chart.Neighborhood)
            ? chart.Neighborhood
            : AllNeighborhood;
    }

    private string EffectiveChartDensity(ChartToolState chart) =>
        ValidationDensityOptions.Contains(chart.Density)
            ? chart.Density
            : AllDensity;

    private string EffectiveChartBreakdown(ChartToolState chart)
    {
        var options = ChartBreakdownOptions(chart);
        return options.Contains(chart.Breakdown)
            ? chart.Breakdown
            : options.FirstOrDefault() ?? "Total";
    }

    private string EffectiveChartValueMode(ChartToolState chart)
    {
        var selection = new ChartSelection(
            chart.Measure is "students" or "cohort" or "homes" or "generation" or "family" or "turnover" ? chart.Measure : "students",
            EffectiveChartNeighborhood(chart),
            EffectiveChartDensity(chart),
            EffectiveChartBreakdown(chart),
            chart.ValueMode);
        var options = ChartValueModeOptions(selection);
        return options.Any(option => option.Key.Equals(chart.ValueMode, StringComparison.OrdinalIgnoreCase))
            ? chart.ValueMode
            : "value";
    }

    private ChartSelection CurrentChartSelection(ChartToolState chart) =>
        new(
            chart.Measure is "students" or "cohort" or "homes" or "generation" or "family" or "turnover" ? chart.Measure : "students",
            EffectiveChartNeighborhood(chart),
            EffectiveChartDensity(chart),
            EffectiveChartBreakdown(chart),
            EffectiveChartValueMode(chart));

    private static string ChartSelectionKey(ChartSelection selection) =>
        $"{selection.Measure}|{selection.Neighborhood}|{selection.Density}|{selection.Breakdown}|{selection.ValueMode}";

    private string ChartSelectionLabel(ChartSelection selection) =>
        $"{ChartMeasureLabel(selection.Measure)}: {FormatValidationNeighborhood(selection.Neighborhood)} / {selection.Density} / {FormatChartBreakdown(selection.Measure, selection.Breakdown)} / {ChartValueModeLabel(selection)}";

    private string ChartValueModeLabel(ChartSelection selection) =>
        ChartValueModeOptions(selection).FirstOrDefault(option => option.Key.Equals(selection.ValueMode, StringComparison.OrdinalIgnoreCase))?.Label ?? "Count";

    private static string ChartMeasureLabel(string measure) => measure switch
    {
        "cohort" => "Student Cohort",
        "homes" => "Homes",
        "generation" => "Student Generation",
        "family" => "Family Profile",
        "turnover" => "Turnover",
        _ => "Students"
    };

    private string FormatChartBreakdown(ChartToolState chart, string breakdown) => FormatChartBreakdown(chart.Measure, breakdown);

    private static string FormatChartBreakdown(string measure, string breakdown)
    {
        return measure is "students" or "generation"
            && breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
                ? "All grades"
                : breakdown;
    }

    private bool ChartSupportsShare(ChartSelection selection) => selection.Measure switch
    {
        "students" or "cohort" => !selection.Breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
            || !selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
            || !selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase),
        "homes" => !selection.Breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase),
        "family" => true,
        _ => false
    };

    private bool ChartHasReference(ChartSelection selection) =>
        Result?.Comparisons.Select(comparison => ChartReferenceBaseValue(selection, comparison)).Any(value => value.HasValue) == true;

    private Func<double, string> ChartFormatter(ChartSelection selection) => selection.ValueMode switch
    {
        "share" or "previous-percent" or "start-percent" or "percent-error" => FormatPercent,
        "value" when selection.Measure is "generation" => FormatGeneration,
        "value" when selection.Measure is "turnover" && selection.Breakdown.Equals("Turnover factor", StringComparison.OrdinalIgnoreCase) => FormatPercent,
        "value" when selection.Measure is "turnover" && selection.Breakdown.Equals("Average longevity", StringComparison.OrdinalIgnoreCase) => value => $"{value:0.0} yrs",
        _ => FormatCount
    };

    private ValidationChartCache CurrentChart(ChartToolState chart)
    {
        var selection = CurrentChartSelection(chart);
        var key = $"{ValidationResultVersion}|{ChartSelectionKey(selection)}";
        if (chart.CacheValue is not null && chart.CacheKey == key)
        {
            return chart.CacheValue;
        }

        chart.CacheValue = BuildChartCache(chart, selection, chart.PinnedSelections.Count);
        chart.CacheKey = key;
        return chart.CacheValue;
    }

    private ValidationChartCache BuildChartCache(ChartToolState chart, ChartSelection selection, int colorIndex)
    {
        var modeledBase = Result?.Comparisons.Select(comparison => ChartModeledBaseValue(chart, selection, comparison)).ToList() ?? [];
        var referenceBase = Result?.Comparisons.Select(comparison => ChartReferenceBaseValue(selection, comparison)).ToList() ?? [];
        var modeledValues = TransformChartValues(chart, selection, modeledBase, reference: false);
        var referenceValues = TransformChartValues(chart, selection, referenceBase, reference: true);
        var modeledStdDevs = TransformChartStandardDeviations(chart, selection, Result?.Comparisons.Select(comparison => ChartModeledStandardDeviationBaseValue(chart, selection, comparison)).ToList() ?? [], modeledBase);
        var absoluteErrors = referenceBase
            .Zip(modeledBase, (reference, modeled) => reference.HasValue && modeled.HasValue ? Math.Abs(modeled.Value - reference.Value) : (double?)null)
            .ToList();
        var percentErrors = referenceBase
            .Zip(modeledBase, (reference, modeled) => reference is > 0 && modeled.HasValue ? Math.Abs(modeled.Value - reference.Value) / reference.Value : (double?)null)
            .ToList();
        var color = ValidationColorForIndex(colorIndex);
        var hasReference = referenceBase.Any(value => value.HasValue);
        var series = selection.ValueMode switch
        {
            "absolute-error" => new List<ValidationChartLine> { new("Absolute error", color, absoluteErrors, FormatCount, "") },
            "percent-error" => new List<ValidationChartLine> { new("Percentage error", color, percentErrors, FormatPercent, "") },
            _ => hasReference
                ?
                [
                    new("Reference", color, referenceValues, ChartFormatter(selection), "7 5"),
                    BuildModeledChartLine(ChartModeledSeriesLabel(selection), color, modeledValues, modeledStdDevs, ChartFormatter(selection))
                ]
                :
                [
                    BuildModeledChartLine(ChartModeledSeriesLabel(selection), color, modeledValues, modeledStdDevs, ChartFormatter(selection))
                ]
        };
        var numbers = series
            .SelectMany(item => item.Values
                .Concat(item.OneSigmaLowValues ?? [])
                .Concat(item.OneSigmaHighValues ?? [])
                .Concat(item.TwoSigmaLowValues ?? [])
                .Concat(item.TwoSigmaHighValues ?? []))
            .Where(value => value.HasValue)
            .Select(value => value!.Value)
            .ToList();
        var max = 1.0;
        var min = 0.0;
        if (numbers.Count > 0)
        {
            var rawMax = numbers.Max();
            var rawMin = numbers.Min();
            if (rawMin < 0)
            {
                max = ChartAxis.NiceMaximum(Math.Max(Math.Abs(rawMin), Math.Abs(rawMax)) * 1.08);
                min = -max;
            }
            else
            {
                max = ChartAxis.NiceMaximum(Math.Max(1, rawMax * 1.08));
            }
        }

        return new ValidationChartCache(
            modeledValues,
            referenceValues,
            absoluteErrors,
            percentErrors,
            series,
            numbers,
            max,
            min,
            Math.Max(1, max - min));
    }

    private static string ChartModeledSeriesLabel(ChartSelection selection) => selection.Measure switch
    {
        "homes" => "Homes",
        _ => "Simulation mean"
    };

    private double? ChartModeledBaseValue(ChartToolState chart, ChartSelection selection, MonteCarloYearComparison comparison)
    {
        var segment = SegmentStatsForYear(chart, selection, comparison.Year);
        return selection.Measure switch
        {
            "homes" => HomesValue(chart, selection, comparison.Year, selection.Neighborhood, selection.Density, selection.Breakdown),
            "cohort" => CohortValue(chart, selection, comparison, modeled: true),
            "generation" => StudentGenerationValue(chart, selection, comparison, modeled: true),
            "family" => FamilyValue(selection, segment),
            "turnover" => TurnoverValue(selection, segment),
            _ => StudentValue(chart, selection, comparison, modeled: true)
        };
    }

    private double? ChartReferenceBaseValue(ChartSelection selection, MonteCarloYearComparison comparison)
    {
        return selection.Measure switch
        {
            "cohort" => CohortValue(null, selection, comparison, modeled: false),
            "generation" => StudentGenerationReferenceValue(selection, comparison),
            "students" => StudentValue(null, selection, comparison, modeled: false),
            _ => null
        };
    }

    private double? ChartModeledStandardDeviationBaseValue(ChartToolState chart, ChartSelection selection, MonteCarloYearComparison comparison)
    {
        return selection.Measure switch
        {
            "cohort" => CohortStandardDeviation(selection, comparison),
            "students" => StudentStandardDeviation(selection, comparison),
            _ => null
        };
    }

    private double? StudentValue(ChartToolState? chart, ChartSelection selection, MonteCarloYearComparison comparison, bool modeled)
    {
        return StudentValue(chart, selection, comparison, modeled, selection.Breakdown);
    }

    private double? StudentValue(ChartToolState? chart, ChartSelection selection, MonteCarloYearComparison comparison, bool modeled, string breakdown)
    {
        if (!modeled && !HasReferenceData(comparison))
        {
            return null;
        }

        if (!modeled && !selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        if (!selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
            || !selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
        {
            if (!modeled)
            {
                return breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
                    && !selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                        ? comparison.ActualGridTotals.GetValueOrDefault(selection.Neighborhood)
                        : null;
            }

            return chart is null ? null : SegmentStudentValue(chart, selection, comparison.Year, breakdown);
        }

        return modeled
            ? ModeledStudentBreakdown(comparison, breakdown)
            : ReferenceStudentBreakdown(comparison, breakdown);
    }

    private double? StudentGenerationValue(ChartToolState chart, ChartSelection selection, MonteCarloYearComparison comparison, bool modeled)
    {
        var students = StudentValueForGeneration(chart, selection, comparison, modeled);
        var homes = HomesValue(chart, selection, comparison.Year, selection.Neighborhood, selection.Density, "Total");
        return students.HasValue && homes is > 0 ? students.Value / homes.Value : null;
    }

    private double? StudentGenerationReferenceValue(ChartSelection selection, MonteCarloYearComparison comparison)
    {
        var students = StudentValueForGeneration(null, selection, comparison, modeled: false);
        var homes = HomesValueForSelection(comparison.Year, selection.Neighborhood, selection.Density);
        return students.HasValue && homes is > 0 ? students.Value / homes.Value : null;
    }

    private double? CohortValue(ChartToolState? chart, ChartSelection selection, MonteCarloYearComparison comparison, bool modeled)
    {
        var cohort = CohortForLabel(selection.Breakdown);
        var grade = cohort is null ? null : GradeForCohort(cohort, comparison.Year);
        if (grade is null)
        {
            return null;
        }

        if (!modeled && !HasReferenceData(comparison))
        {
            return null;
        }

        if (!modeled
            && (!selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase)
                || !selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)))
        {
            return null;
        }

        if (modeled
            && (!selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                || !selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase)))
        {
            return chart is null ? null : SegmentStatsForYear(chart, selection, comparison.Year).Grades.GetValueOrDefault(grade);
        }

        return modeled
            ? comparison.ModeledGrades.GetValueOrDefault(grade)
            : comparison.AdjustedActualGrades.GetValueOrDefault(grade);
    }

    private double? CohortStandardDeviation(ChartSelection selection, MonteCarloYearComparison comparison)
    {
        var cohort = CohortForLabel(selection.Breakdown);
        var grade = cohort is null ? null : GradeForCohort(cohort, comparison.Year);
        if (grade is null)
        {
            return null;
        }

        if (!selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
            || !selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
        {
            return selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase)
                && !selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                ? comparison.ModeledGridGradeStandardDeviations.GetValueOrDefault(selection.Neighborhood)?.GetValueOrDefault(grade)
                : null;
        }

        return comparison.ModeledGradeStandardDeviations.GetValueOrDefault(grade);
    }

    private static double? StudentStandardDeviation(ChartSelection selection, MonteCarloYearComparison comparison)
    {
        if (!selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        if (!selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase))
        {
            return selection.Breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
                ? comparison.ModeledGridTotalStandardDeviations.GetValueOrDefault(selection.Neighborhood)
                : comparison.ModeledGridGradeStandardDeviations.GetValueOrDefault(selection.Neighborhood)?.GetValueOrDefault(selection.Breakdown);
        }

        return selection.Breakdown switch
        {
            "Total" or "K-12" => comparison.ModeledGradeTotalStandardDeviation,
            "HS" => comparison.HighSchoolModeledTotalStandardDeviation,
            "K-8" => null,
            _ => comparison.ModeledGradeStandardDeviations.GetValueOrDefault(selection.Breakdown)
        };
    }

    private double? StudentValueForGeneration(ChartToolState? chart, ChartSelection selection, MonteCarloYearComparison comparison, bool modeled)
    {
        if ((!selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                || !selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase))
            && !selection.Breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
            && !modeled)
        {
            return null;
        }

        return StudentValue(chart, selection, comparison, modeled, selection.Breakdown);
    }

    private IReadOnlyList<double?> TransformChartValues(ChartToolState chart, ChartSelection selection, IReadOnlyList<double?> values, bool reference)
    {
        return selection.ValueMode switch
        {
            "share" => Result?.Comparisons.Select((comparison, index) =>
            {
                var value = values.ElementAtOrDefault(index);
                var denominator = ChartShareDenominator(chart, selection, comparison, reference);
                return value.HasValue && denominator is > 0 ? value.Value / denominator.Value : (double?)null;
            }).ToList() ?? [],
            "previous-change" => TransformAgainstPrevious(values, percent: false),
            "previous-percent" => TransformAgainstPrevious(values, percent: true),
            "start-change" => TransformAgainstStart(values, percent: false),
            "start-percent" => TransformAgainstStart(values, percent: true),
            _ => values
        };
    }

    private IReadOnlyList<double?> TransformChartStandardDeviations(
        ChartToolState chart,
        ChartSelection selection,
        IReadOnlyList<double?> standardDeviations,
        IReadOnlyList<double?> modeledBaseValues)
    {
        return selection.ValueMode.Equals("value", StringComparison.OrdinalIgnoreCase)
            ? standardDeviations
            : modeledBaseValues.Select(_ => (double?)null).ToList();
    }

    private double? ChartShareDenominator(ChartToolState chart, ChartSelection selection, MonteCarloYearComparison comparison, bool reference)
    {
        return selection.Measure switch
        {
            "students" or "cohort" => selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                    && selection.Density.Equals(AllDensity, StringComparison.OrdinalIgnoreCase)
                ? StudentValue(chart, selection, comparison, modeled: !reference, "Total")
                : selection.Breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
                    ? StudentValue(chart, selection, comparison, modeled: !reference, "Total")
                    : StudentValue(chart, selection, comparison, modeled: true, "Total"),
            "homes" => HomesValue(chart, selection, comparison.Year, selection.Neighborhood, selection.Density, "Total"),
            "family" => SegmentStatsForYear(chart, selection, comparison.Year).TotalHomes,
            _ => null
        };
    }

    private SegmentStats SegmentStatsForYear(ChartToolState chart, ChartSelection selection, int year)
    {
        var key = $"{ValidationResultVersion}|{year}|{selection.Neighborhood}|{selection.Density}";
        if (chart.SegmentStatsCache.TryGetValue(key, out var cached))
        {
            return cached;
        }

        var segments = SimulationInfoForYear(year)?.Segments ?? [];
        var selected = segments
            .Where(segment => selection.Neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                || segment.Grid.Equals(selection.Neighborhood, StringComparison.OrdinalIgnoreCase))
            .Where(segment => DensityMatchesSelection(segment.Density, selection.Density))
            .ToList();

        var grades = GradeOrder.ToDictionary(
            grade => grade,
            grade => selected.Sum(segment => segment.Grades.GetValueOrDefault(grade)),
            StringComparer.OrdinalIgnoreCase);
        var turnoverEvents = selected.Sum(segment => segment.TurnoverEvents);
        var result = new SegmentStats(
            selected.Sum(segment => segment.TotalHomes),
            grades,
            selected.Sum(segment => segment.FamiliesWithZeroChildren),
            selected.Sum(segment => segment.FamiliesWithOneChild),
            selected.Sum(segment => segment.FamiliesWithTwoChildren),
            selected.Sum(segment => segment.FamiliesWithThreeChildren),
            selected.Sum(segment => segment.FamiliesWithFourPlusChildren),
            turnoverEvents,
            turnoverEvents > 0
                ? selected.Sum(segment => segment.AverageLongevityBeforeTurnover * segment.TurnoverEvents) / turnoverEvents
                : 0);
        chart.SegmentStatsCache[key] = result;
        return result;
    }

    private double SegmentStudentValue(ChartToolState chart, ChartSelection selection, int year, string breakdown)
    {
        var grades = SegmentStatsForYear(chart, selection, year).Grades;
        return breakdown switch
        {
            "Total" or "K-12" => SumGrades(grades, K8Grades.Concat(HighSchoolGrades).Append("Sp. Ed.")),
            "K-8" => SumGrades(grades, K8Grades),
            "HS" => SumGrades(grades, HighSchoolGrades),
            _ => grades.GetValueOrDefault(breakdown)
        };
    }

    private double? HomesValue(ChartToolState chart, ChartSelection selection, int year, string neighborhood, string density, string breakdown)
    {
        return breakdown.Equals("Total", StringComparison.OrdinalIgnoreCase)
            ? SegmentStatsForYear(chart, selection with { Neighborhood = neighborhood, Density = density }, year).TotalHomes
            : HomesValueForSelection(year, neighborhood, breakdown);
    }

    private double? HomesValueForSelection(int year, string neighborhood, string breakdown)
    {
        var segments = SimulationInfoForYear(year)?.Segments ?? [];
        return segments
            .Where(segment => neighborhood.Equals(AllNeighborhood, StringComparison.OrdinalIgnoreCase)
                || segment.Grid.Equals(neighborhood, StringComparison.OrdinalIgnoreCase))
            .Where(segment => DensityMatchesSelection(segment.Density, breakdown))
            .Sum(segment => segment.TotalHomes);
    }

    private static double? FamilyValue(ChartSelection selection, SegmentStats year)
    {
        return selection.Breakdown switch
        {
            "0 kids" => year.FamiliesWithZeroChildren,
            "1 kid" => year.FamiliesWithOneChild,
            "2 kids" => year.FamiliesWithTwoChildren,
            "3 kids" => year.FamiliesWithThreeChildren,
            "4+ kids" => year.FamiliesWithFourPlusChildren,
            _ => null
        };
    }

    private static double? TurnoverValue(ChartSelection selection, SegmentStats year)
    {
        return selection.Breakdown switch
        {
            "Turnover factor" => year.TotalHomes > 0 ? year.TurnoverEvents / year.TotalHomes : 0,
            "Average longevity" => year.AverageLongevityBeforeTurnover,
            _ => year.TurnoverEvents
        };
    }

    private IReadOnlyList<ValidationLegendGroup> ChartLegendGroups(ChartToolState chart)
    {
        var groups = chart.PinnedSelections
            .Select((selection, index) => new ValidationLegendGroup(
                selection.Id,
                ChartSelectionLabel(selection.Selection),
                BuildChartCache(chart, selection.Selection, index).Series))
            .ToList();
        var current = CurrentChartSelection(chart);
        if (!chart.PinnedSelections.Any(selection => ChartSelectionKey(selection.Selection).Equals(ChartSelectionKey(current), StringComparison.OrdinalIgnoreCase)))
        {
            groups.Add(new ValidationLegendGroup(null, ChartSelectionLabel(current), CurrentChart(chart).Series));
        }

        return groups;
    }

    private IReadOnlyList<ValidationChartLine> ChartSeries(ChartToolState chart) => ChartLegendGroups(chart)
        .SelectMany(group => group.Series.Select(series => series with { HoverLabel = $"{group.Label} {series.Label}" }))
        .ToList();

    private void PinChartSelection(ChartToolState chart)
    {
        var selection = CurrentChartSelection(chart);
        var key = ChartSelectionKey(selection);
        if (chart.PinnedSelections.Any(pin => ChartSelectionKey(pin.Selection).Equals(key, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        chart.PinnedSelections.Add(new ChartPinnedSelection(chart.NextPinnedSelectionId++, selection));
        InvalidateChart(chart);
    }

    private static void RemoveChartSelection(ChartToolState chart, int id)
    {
        chart.PinnedSelections.RemoveAll(selection => selection.Id == id);
        InvalidateChart(chart);
    }

    private static void InvalidateChart(ChartToolState chart)
    {
        chart.CacheKey = null;
        chart.CacheValue = null;
        chart.SegmentStatsCache.Clear();
    }

    private static void FinishChartTitleEdit(ChartToolState chart)
    {
        chart.Title = string.IsNullOrWhiteSpace(chart.Title)
            ? "Chart"
            : chart.Title.Trim();
        chart.EditingTitle = false;
    }

    private static void OnChartTitleKeyDown(ChartToolState chart, KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or "Escape")
        {
            FinishChartTitleEdit(chart);
        }
    }

    private static string LegendSeriesLabel(ValidationChartLine series, int? hoverIndex)
    {
        if (!hoverIndex.HasValue)
        {
            return series.Label;
        }

        var value = series.Values.ElementAtOrDefault(hoverIndex.Value);
        if (!value.HasValue)
        {
            return $"{series.Label}: n/a";
        }

        var deviation = series.StandardDeviations?.ElementAtOrDefault(hoverIndex.Value);
        var suffix = deviation is > 0
            ? $" ±{series.Formatter(deviation.Value)} σ, SE {series.Formatter(StandardError(deviation.Value, series.Runs))}"
            : "";
        return $"{series.Label}: {series.Formatter(value.Value)}{suffix}";
    }

    private string ChartYearsJson => JsonSerializer.Serialize(Result?.Comparisons.Select(item => item.Year.ToString(CultureInfo.InvariantCulture)).ToList() ?? []);

    private static string ChartYValuesJson(IReadOnlyList<double?> values, Func<double, double> ySelector)
    {
        return JsonSerializer.Serialize(values.Select(value => value.HasValue ? Math.Round(ySelector(value.Value), 2) : (double?)null).ToList());
    }

    private static string ChartLegendLabelsJson(ValidationChartLine series)
    {
        return JsonSerializer.Serialize(series.Values.Select((_, index) => LegendSeriesLabel(series, index)).ToList());
    }

    private static double ChartLegendReserveWidthCh(ValidationChartLine series)
    {
        var maxLength = series.Values
            .Select((_, index) => LegendSeriesLabel(series, index).Length)
            .Append(series.Label.Length)
            .DefaultIfEmpty(series.Label.Length)
            .Max();
        return Math.Max(series.Label.Length, maxLength) + 1;
    }

    private double StandardError(double standardDeviation)
    {
        return StandardError(standardDeviation, Result?.Parameters.Runs ?? Runs);
    }

    private static double StandardError(double standardDeviation, int runs)
    {
        return runs > 0 ? standardDeviation / Math.Sqrt(runs) : 0;
    }

    private static string ValueFirstHoverLabel(string label)
    {
        var split = label.LastIndexOf(": ", StringComparison.Ordinal);
        return split > 0 && split + 2 < label.Length
            ? $"{label[(split + 2)..]} - {label[..split]}"
            : label;
    }

    private IReadOnlyList<(double Y, string Label)> ChartYTicks(ChartToolState chart)
    {
        var bounds = ChartAxisBoundsFor(chart);
        return Enumerable.Range(0, 5)
            .Select(index =>
            {
                var value = bounds.Max - ((bounds.Max - bounds.Min) * index / 4);
                var y = ChartYForValue(value, bounds);
                return (y, ChartFormatter(CurrentChartSelection(chart))(value));
            })
            .ToList();
    }

    private string ChartPoints(ChartToolState chart, IReadOnlyList<double?> values)
    {
        if (values.Count == 0) return "";
        return string.Join(" ", values.Select((value, index) =>
        {
            if (!value.HasValue) return null;
            var x = values.Count == 1 ? 60 : 60 + (index * 800.0 / (values.Count - 1));
            var y = ChartYForValue(value.Value, ChartAxisBoundsFor(chart));
            return $"{x:0.##},{y:0.##}";
        }).Where(point => point is not null));
    }

    private string ChartBandPoints(ChartToolState chart, ValidationChartLine series, int sigmaMultiplier)
    {
        return ChartBandPoints(series, sigmaMultiplier, value => ChartYForValue(chart, value));
    }

    private double ChartXForIndex(int index)
    {
        var points = Result?.Comparisons ?? [];
        return points.Count == 1 ? 60 : 60 + (index * 800.0 / Math.Max(1, points.Count - 1));
    }

    private double ChartYForValue(ChartToolState chart, double value)
    {
        return ChartYForValue(value, ChartAxisBoundsFor(chart));
    }

    private static double ChartYForValue(double value, ChartAxisBounds bounds)
    {
        return 260 - ((value - bounds.Min) / bounds.Span * 220);
    }

    private ChartAxisBounds ChartAxisBoundsFor(ChartToolState chart)
    {
        var numbers = ChartSeries(chart)
            .SelectMany(series => series.Values
                .Concat(series.OneSigmaLowValues ?? [])
                .Concat(series.OneSigmaHighValues ?? [])
                .Concat(series.TwoSigmaLowValues ?? [])
                .Concat(series.TwoSigmaHighValues ?? []))
            .Where(value => value.HasValue)
            .Select(value => value!.Value)
            .ToList();

        if (numbers.Count == 0)
        {
            return new ChartAxisBounds(1, 0, 1);
        }

        var max = numbers.Max();
        var min = numbers.Min();
        if (min < 0)
        {
            var absoluteMax = ChartAxis.NiceMaximum(Math.Max(Math.Abs(min), Math.Abs(max)) * 1.08);
            return new ChartAxisBounds(absoluteMax, -absoluteMax, absoluteMax * 2);
        }

        var niceMax = ChartAxis.NiceMaximum(Math.Max(1, max * 1.08));
        return new ChartAxisBounds(niceMax, 0, Math.Max(1, niceMax));
    }

    private double ChartHoverX(ChartToolState chart) => chart.HoverIndex.HasValue ? ChartXForIndex(chart.HoverIndex.Value) : 60;

    private double ChartHoverYearLabelX(ChartToolState chart) => Math.Clamp(ChartHoverX(chart) - 29, 62, 802);

    private double ChartHoverPanelX(ChartToolState chart) => ChartHoverX(chart) > 650 ? 405 : 650;

    private static string ChartSvgElementId(ChartToolState chart) => $"chart-svg-{chart.Id}";

    private IReadOnlyList<(int Index, double X, double Width)> ChartHoverZones
    {
        get
        {
            var points = Result?.Comparisons ?? [];
            if (points.Count == 0) return [];
            if (points.Count == 1) return [(0, 60, 800)];

            var zones = new List<(int Index, double X, double Width)>();
            for (var index = 0; index < points.Count; index++)
            {
                var previousMid = index == 0 ? 60 : (ChartXForIndex(index - 1) + ChartXForIndex(index)) / 2;
                var nextMid = index == points.Count - 1 ? 860 : (ChartXForIndex(index) + ChartXForIndex(index + 1)) / 2;
                zones.Add((index, previousMid, nextMid - previousMid));
            }

            return zones;
        }
    }

    private IReadOnlyList<(double X, double Y, string Label, string Color)> ChartHoverMarkers(ChartToolState chart)
    {
        var points = Result?.Comparisons ?? [];
        if (!chart.HoverIndex.HasValue || chart.HoverIndex.Value < 0 || chart.HoverIndex.Value >= points.Count) return [];

        var index = chart.HoverIndex.Value;
        var x = ChartXForIndex(index);
        return ChartSeries(chart)
            .Select(series => new { series, Value = series.Values.ElementAtOrDefault(index) })
            .Where(item => item.Value.HasValue)
            .Select(item => (
                x,
                ChartYForValue(chart, item.Value!.Value),
                $"{item.series.HoverLabel}: {item.series.Formatter(item.Value.Value)}",
                item.series.Color))
            .ToList();
    }

    private void OnChartMeasureChanged(ChartToolState chart, ChangeEventArgs args)
    {
        chart.Measure = args.Value?.ToString() ?? "students";
        NormalizeChartSelections(chart, resetNeighborhood: true, resetBreakdown: true, resetValueMode: true);
    }

