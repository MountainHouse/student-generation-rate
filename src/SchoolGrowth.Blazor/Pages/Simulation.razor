            @foreach (var tool in InactiveTools)
            {
                <option value="@tool.Id">@tool.Title</option>
            }
        </select>
    </section>
    </div>
}

@code {
    private static readonly IReadOnlyList<string> GradeOrder =
    [
        "TK", "K", "1st", "2nd", "3rd", "4th", "5th", "6th", "7th", "8th",
        "9th", "10th", "11th", "12th", "Sp. Ed."
    ];
    private static readonly IReadOnlyList<string> VisibleGradeOrder =
        GradeOrder.Where(grade => !grade.Equals("TK", StringComparison.OrdinalIgnoreCase)).ToList();
    private static readonly IReadOnlyList<string> VisibleCohortGrades =
        VisibleGradeOrder.Where(grade => !grade.Equals("Sp. Ed.", StringComparison.OrdinalIgnoreCase)).ToList();
    private static readonly IReadOnlyList<ProjectionSubtotal> GradeSubtotals =
    [
        new("K-5", ["K", "1st", "2nd", "3rd", "4th", "5th"]),
        new("5-8", ["5th", "6th", "7th", "8th"]),
        new("K-8", ["K", "1st", "2nd", "3rd", "4th", "5th", "6th", "7th", "8th"]),
        new("HS", ["9th", "10th", "11th", "12th"])
    ];
    private static readonly HashSet<string> ExcludedValidationGrids = new(StringComparer.OrdinalIgnoreCase)
    {
        "Inter-Districts",
        "Lammersville",
        "MHESD"
    };
    private static readonly MonteCarloParameters DefaultParameters = new();
    private const string CustomPresetName = "Custom";
    private const string ToolRunEnvironment = "run-environment";
    private const string ToolModelSettings = "model-settings";
    private const string ToolModelScoring = "model-scoring";
    private const string ToolValidationSummary = "validation-summary";
    private const string ToolSimulationInfo = "simulation-info";
    private const string ToolDataGaps = "data-gaps";
    private const string ToolTableDetails = "table-details";
    private const string ToolCohorts = "cohorts";
    private const string ToolGrades = "grades";
    private const string ToolGridTotals = "grid-totals";
    private const string ToolParameterSearch = "parameter-search";
    private const string ToolModeledReference = "modeled-reference";
    private const string ToolGridDetail = "grid-detail";
    private const string ToolGradeDetail = "grade-detail";
    private const string ToolRules = "rules";
    private static readonly IReadOnlyList<MonteCarloToolDefinition> ToolDefinitions =
    [
        new(ToolRunEnvironment, "Run Environment"),
        new(ToolModelSettings, "Model Settings"),
        new(ToolModelScoring, "Model Scoring"),
        new(ToolValidationSummary, "Validation Summary"),
        new(ToolSimulationInfo, "Simulation Info"),
        new(ToolDataGaps, "Data Gaps"),
        new(ToolTableDetails, "Table Details"),
        new(ToolCohorts, "Progressing Cohorts"),
        new(ToolGrades, "Grades"),
        new(ToolGridTotals, "Grid Totals"),
        new(ToolParameterSearch, "Parameter Search"),
        new(ToolModeledReference, "Modeled vs Reference Totals"),
        new(ToolGridDetail, "Grid Detail"),
        new(ToolGradeDetail, "Grade Detail"),
        new(ToolRules, "Simulation Rules")
    ];
    private static readonly HashSet<string> ResultToolIds =
    [
        ToolValidationSummary,
        ToolSimulationInfo,
        ToolDataGaps,
        ToolTableDetails,
        ToolCohorts,
        ToolGrades,
        ToolGridTotals,
        ToolParameterSearch,
        ToolModeledReference,
        ToolGridDetail,
        ToolGradeDetail,
        ToolRules
    ];

    private EnrollmentData? Data { get; set; }
