               Collapsed="@IsToolCollapsed(ToolGradeDetail)" CanMoveUp="@CanMoveToolUp(ToolGradeDetail)" CanMoveDown="@CanMoveToolDown(ToolGradeDetail)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
