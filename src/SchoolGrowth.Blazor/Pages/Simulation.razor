    private void NormalizeChartSelections(
        ChartToolState chart,
        bool resetNeighborhood = false,
        bool resetBreakdown = false,
        bool resetValueMode = false)
    {
        if (!new[] { "students", "cohort", "homes", "generation", "family", "turnover" }.Contains(chart.Measure))
        {
            chart.Measure = "students";
        }

        if (resetNeighborhood || !ChartNeighborhoodOptions(chart).Contains(chart.Neighborhood))
        {
            chart.Neighborhood = ChartNeighborhoodOptions(chart).FirstOrDefault() ?? AllNeighborhood;
        }

        if (!ValidationDensityOptions.Contains(chart.Density))
        {
            chart.Density = AllDensity;
        }

        if (resetBreakdown || !ChartBreakdownOptions(chart).Contains(chart.Breakdown))
        {
            chart.Breakdown = ChartBreakdownOptions(chart).FirstOrDefault() ?? "Total";
        }

        if (resetValueMode || !ChartValueModeOptions(chart).Any(option => option.Key.Equals(chart.ValueMode, StringComparison.OrdinalIgnoreCase)))
        {
            chart.ValueMode = "value";
        }

        chart.HoverIndex = null;
        InvalidateChart(chart);
    }

    [JSInvokable]
    public async Task SetValidationHoverIndex(int index)
    {
        await SetChartHoverIndex(ToolValidationSummary, index);
    }

    [JSInvokable]
    public async Task SetChartHoverIndex(string chartId, int index)
    {
        var next = index < 0 ? (int?)null : index;
        if (chartId.Equals(ToolValidationSummary, StringComparison.OrdinalIgnoreCase))
        {
            if (TotalChartHoverIndex == next)
            {
                return;
            }

            TotalChartHoverIndex = next;
            ValidationHoverRenderPending = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var chart = ChartTools.FirstOrDefault(item => item.Id.Equals(chartId, StringComparison.OrdinalIgnoreCase));
        if (chart is null || chart.HoverIndex == next)
        {
            return;
        }

        chart.HoverIndex = next;
        ChartHoverRenderPending = true;
        await InvokeAsync(StateHasChanged);
    }

