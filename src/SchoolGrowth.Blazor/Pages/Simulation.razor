                    <dt>Special ed probability</dt>
                    <dd>@SearchResult.Best.Parameters.SpecialEducationProbability.ToString("P1")</dd>
                    <dt>Births/year</dt>
                    <dd>@SearchResult.Best.Parameters.AnnualFirstNewChildProbability.ToString("P1") / @SearchResult.Best.Parameters.AnnualSecondNewChildProbability.ToString("P1") / @SearchResult.Best.Parameters.AnnualThirdNewChildProbability.ToString("P1") / @SearchResult.Best.Parameters.AnnualFourthPlusNewChildProbability.ToString("P1")</dd>
                    <dt>Non-student weights</dt>
