    private static double? ReferenceGeneration(MonteCarloSimulationYearInfo year, double? referenceStudents)
    {
        return referenceStudents.HasValue && year.TotalHomes > 0
            ? referenceStudents.Value / year.TotalHomes
            : null;
    }

    private double? ReferenceDensityGeneration(MonteCarloSimulationYearInfo year, string densityGroup, double? referenceStudents)
    {
        var comparison = ComparisonForYear(year.Year);
        if (Data is null || comparison is null || !referenceStudents.HasValue || comparison.ActualGradeTotal <= 0)
        {
            return null;
        }

        var districtGradeShare = referenceStudents.Value / comparison.ActualGradeTotal;
        var referenceStudentsInDensity = 0.0;
        var homesInDensity = 0.0;

        foreach (var (grid, actualTotal) in comparison.ActualGridTotals)
        {
            if (ExcludedValidationGrids.Contains(grid) || actualTotal is not > 0)
            {
                continue;
            }

            var gridHomes = BuiltHomesForGrid(grid, year.Year, "all");
            var gridDensityHomes = BuiltHomesForGrid(grid, year.Year, densityGroup);
            if (gridHomes <= 0 || gridDensityHomes <= 0)
            {
                continue;
            }

            referenceStudentsInDensity += actualTotal.Value * (gridDensityHomes / gridHomes) * districtGradeShare;
            homesInDensity += gridDensityHomes;
        }

        return homesInDensity > 0 ? referenceStudentsInDensity / homesInDensity : null;
    }

    private double BuiltHomesForGrid(string grid, int year, string densityGroup)
    {
        if (Data is null)
        {
            return 0;
        }

        return Data.HomeRows
            .Where(row => row.Neighborhood.Equals(grid, StringComparison.OrdinalIgnoreCase))
            .Where(row => densityGroup.Equals("all", StringComparison.OrdinalIgnoreCase)
                || DensityGroupMatches(row.Density, densityGroup))
            .Sum(row => row.HomesByYear
                .Where(kvp => kvp.Key <= year)
                .Sum(kvp => kvp.Value));
    }

    private static bool DensityGroupMatches(string density, string densityGroup)
    {
        var normalizedDensity = NormalizeDensity(density);
        return densityGroup switch
        {
            "low" => normalizedDensity is "RL",
            "medium" => normalizedDensity is "RM",
            "medium-high" => normalizedDensity is "RMH",
            "high" => normalizedDensity is "RH",
            "other" => normalizedDensity is "EXISTING" or "OTHER",
            "low-medium" => normalizedDensity is "RL" or "RM",
            "medium-high-high" => normalizedDensity is "RMH" or "RH",
            _ => false
        };
    }

    private static bool HasGradeReferenceData(MonteCarloYearComparison? comparison)
    {
        return comparison is not null && comparison.ActualGradeTotal > 0;
    }

    private static double SumAdjustedGrades(MonteCarloYearComparison comparison, params string[] grades)
    {
        return grades.Sum(grade => comparison.AdjustedActualGrades.GetValueOrDefault(grade));
    }

