    private bool IsToolActive(string id) => ActiveToolIds.Contains(id);

    private bool IsToolCollapsed(string id) => CollapsedToolIds.Contains(id);

    private string ToolStyle(string id) => $"order: {Math.Max(0, ActiveToolIds.IndexOf(id))};";

    private bool CanMoveToolUp(string id) => ActiveToolIds.IndexOf(id) > 0;

    private bool CanMoveToolDown(string id)
    {
        var index = ActiveToolIds.IndexOf(id);
        return index >= 0 && index < ActiveToolIds.Count - 1;
    }

    private void ToggleTool(string id)
    {
        if (!CollapsedToolIds.Add(id))
        {
            CollapsedToolIds.Remove(id);
        }
    }

    private void MoveToolUp(string id)
    {
        var index = ActiveToolIds.IndexOf(id);
        if (index <= 0) return;

        (ActiveToolIds[index - 1], ActiveToolIds[index]) = (ActiveToolIds[index], ActiveToolIds[index - 1]);
    }

    private void MoveToolDown(string id)
    {
        var index = ActiveToolIds.IndexOf(id);
        if (index < 0 || index >= ActiveToolIds.Count - 1) return;

        (ActiveToolIds[index + 1], ActiveToolIds[index]) = (ActiveToolIds[index], ActiveToolIds[index + 1]);
    }

    private void RemoveTool(string id)
    {
        ActiveToolIds.Remove(id);
        CollapsedToolIds.Remove(id);
        if (string.IsNullOrWhiteSpace(NewToolId))
        {
            NewToolId = id;
        }
    }

    private void AddSelectedTool()
    {
        var id = !string.IsNullOrWhiteSpace(NewToolId) && InactiveTools.Any(tool => tool.Id == NewToolId)
            ? NewToolId
            : InactiveTools.FirstOrDefault()?.Id;
        if (string.IsNullOrWhiteSpace(id) || ActiveToolIds.Contains(id)) return;

        ActiveToolIds.Add(id);
        CollapsedToolIds.Remove(id);
        NewToolId = "";
    }

    private async Task AddToolFromSelectionAsync(ChangeEventArgs args)
    {
        var id = args.Value?.ToString();
        NewToolId = "";
        if (string.IsNullOrWhiteSpace(id) || ActiveToolIds.Contains(id)) return;

        ActiveToolIds.Add(id);
        CollapsedToolIds.Remove(id);
        ToolsPopupOpen = false;
        await InvokeAsync(StateHasChanged);
        await ScrollToToolAsync(id);
    }

    private async Task NavigateToToolAsync(string id)
    {
        ToolsPopupOpen = false;
        await ScrollToToolAsync(id);
    }

    private async Task OnToolsPopupChangedAsync()
    {
        if (Data is not null)
        {
            await Js.InvokeVoidAsync("schoolGrowthTools.attachDraggable", ".tool-nav-float");
            await Js.InvokeVoidAsync("schoolGrowthTools.setOpen", ".tool-nav-float", ToolsPopupOpen);
        }
    }

    private async Task ScrollToToolAsync(string id)
    {
        try
        {
            await Task.Delay(50);
            await Js.InvokeVoidAsync("schoolGrowthTools.scrollToTool", id);
        }
        catch
        {
            // Navigation is a convenience; rendering and validation should not depend on it.
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var homes = await Http.GetStringAsync("data/homes.csv");
            var grid = await Http.GetStringAsync("data/grid.csv");
            var grade = await Http.GetStringAsync("data/grade.csv");
            var schools = await Http.GetStringAsync("data/schools.csv");
            Data = EnrollmentData.LoadFromCsvText(homes, grid, grade, schools);
            Model = new MonteCarloEnrollmentModel(Data);
            await LoadPresetsAsync();
            StartYear = Math.Max(MinStartYear, LatestReferenceYear - 5);
            EndYear = LatestReferenceYear;
            SelectedComparisonYear = EndYear;
            await DetectServerApiAsync();
            _ = RunValidationAsync();
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Data is not null)
        {
            if (TrackCustomPreset())
            {
                await InvokeAsync(StateHasChanged);
            }
            await Js.InvokeVoidAsync("schoolGrowthMasonry.attach", ".settings-stack");
            await Js.InvokeVoidAsync("schoolGrowthTables.attach", ".table-wrap");
            await Js.InvokeVoidAsync("schoolGrowthTools.attachDraggable", ".tool-nav-float");
            await Js.InvokeVoidAsync("schoolGrowthTools.setOpen", ".tool-nav-float", ToolsPopupOpen);
        }
    }

    private async Task LoadPresetsAsync()
    {
        try
        {
            var presets = await Http.GetFromJsonAsync<IReadOnlyList<MonteCarloParameterPreset>>("data/simulation-presets.json");
            if (presets is not null && presets.Count > 0)
            {
                ParameterPresets = presets;
                SelectedPresetName = presets.FirstOrDefault(preset => preset.Name.Equals("default", StringComparison.OrdinalIgnoreCase))?.Name
                    ?? presets[0].Name;
                ApplyParameters(SelectedPreset?.Parameters ?? presets[0].Parameters);
            }
        }
        catch
        {
            SelectedPresetName = "default";
            ApplyParameters(DefaultParameters);
        }
    }

    private async Task LoadPresetAsync(ChangeEventArgs args)
    {
        var name = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(name)) return;

        var preset = PresetOptions.FirstOrDefault(item => item.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
        if (preset is null) return;

        SelectedPresetName = preset.Name;
        ApplyParameters(preset.Parameters);
        SearchResult = null;
        await RunValidationAsync();
    }

    private bool TrackCustomPreset()
    {
        var current = CurrentParameters();
        if (SelectedPresetName.Equals(CustomPresetName, StringComparison.OrdinalIgnoreCase))
        {
            CustomParameters = current;
            return false;
        }

        var selectedPreset = ParameterPresets
            .FirstOrDefault(item => item.Name.Equals(SelectedPresetName, StringComparison.OrdinalIgnoreCase));
        if (selectedPreset is null || ParametersMatch(current, selectedPreset.Parameters))
        {
            return false;
        }

        CustomParameters = current;
        SelectedPresetName = CustomPresetName;
        return true;
    }

    private static bool ParametersMatch(MonteCarloParameters left, MonteCarloParameters right) => left.Equals(right);

    private async Task RunValidationAsync()
    {
        if (Model is null) return;
        ValidationDebounce?.Cancel();
        ValidationDebounce?.Dispose();
        var debounce = new CancellationTokenSource();
        ValidationDebounce = debounce;

        try
        {
            await Task.Delay(600, debounce.Token);
            if (!debounce.IsCancellationRequested)
            {
                await ExecuteValidationAsync();
            }
        }
        catch (TaskCanceledException)
        {
            // A newer edit superseded this validation request.
        }
    }

    private async Task ExecuteValidationAsync()
    {
        if (Model is null) return;
        if (ValidationRunning)
        {
            PendingValidation = true;
            return;
        }

        ValidationRunning = true;
        do
        {
            PendingValidation = false;
            var executionLabel = ShouldUseServer() ? "server" : "browser";
            StatusMessage = $"Running simulation validation on {executionLabel}: {Runs:N0} runs...";
            await InvokeAsync(StateHasChanged);
            await Task.Yield();

            var stopwatch = System.Diagnostics.Stopwatch.StartNew();
            try
            {
                var ran = await RunValidationCoreAsync();
                stopwatch.Stop();
                var elapsed = FormatElapsed(stopwatch.Elapsed);
                StatusMessage = ran
                    ? $"Validation complete on {LastExecutionLabel}: {Runs:N0} runs in {elapsed}, score {Result?.CombinedScore:P2}. {ServerApiStatus}"
                    : $"{ServerApiStatus} ({elapsed})";
            }
            catch (Exception ex)
            {
                stopwatch.Stop();
                StatusMessage = $"Validation failed after {FormatElapsed(stopwatch.Elapsed)}: {ex.Message}";
            }
            await InvokeAsync(StateHasChanged);
        }
        while (PendingValidation);

        ValidationRunning = false;
    }

    private async Task<bool> RunValidationCoreAsync()
    {
        if (Model is null) return false;
        StartYear = Math.Clamp(StartYear, MinStartYear, MaxSimulationEndYear);
        EndYear = Math.Clamp(EndYear, StartYear, MaxSimulationEndYear);
        Runs = Math.Clamp(Runs, 1, 10000);

        var request = new MonteCarloValidationRequest(
            StartYear,
            EndYear,
            CurrentParameters());

        if (ShouldUseServer())
        {
            try
            {
                Result = await PostServerAsync<MonteCarloValidationRequest, MonteCarloValidationResult>("api/simulation/validate", request);
                ServerApiAvailable = true;
                ServerApiStatus = $"Server API: {ServerApiBaseAddress}";
                LastExecutionLabel = "server";
            }
            catch (Exception ex) when (ExecutionMode != "Server")
            {
                ServerApiAvailable = false;
                LastExecutionLabel = "none";
                ServerApiStatus = $"Server unavailable; validation was not run in the browser automatically ({ex.Message}). Select Browser only, or restart the server API.";
                return false;
            }
        }
        else
        {
            Result = Model.Validate(request);
            LastExecutionLabel = "browser";
            ServerApiStatus = BrowserOnlyStatus();
        }

        if (Result is null)
        {
            return false;
        }

        if (!Result.Comparisons.Any(item => item.Year == SelectedComparisonYear))
        {
            SelectedComparisonYear = Result.Comparisons.LastOrDefault()?.Year ?? EndYear;
        }

        if (!ComparisonChartEntities.Contains(ComparisonChartEntity))
        {
            ComparisonChartEntity = ComparisonChartEntities.FirstOrDefault() ?? "Validation total";
        }

        return true;
    }

    private async Task FindBest()
    {
        if (Model is null) return;
        SearchRunning = true;
        StatusMessage = "Searching simulation parameter candidates...";
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            var request = new MonteCarloSearchRequest(
                StartYear,
                EndYear,
                Math.Clamp(SearchRuns, 1, 2000),
                Seed,
                ParseCandidates(OwnershipCandidatesText),
                ParseCandidates(ZeroChildCandidatesText),
                ParseCandidates(OneChildCandidatesText),
                ParseCandidates(TwoChildCandidatesText),
                ParseCandidates(ThreeChildCandidatesText),
                ParseCandidates(FourChildCandidatesText),
                Array.Empty<double>(),
                CurrentParameters());

            if (ShouldUseServer())
            {
                try
                {
                    SearchResult = await PostServerAsync<MonteCarloSearchRequest, MonteCarloSearchResult>("api/simulation/search", request);
                    LastExecutionLabel = "server";
                }
                catch (Exception ex) when (ExecutionMode != "Server")
                {
                    ServerApiAvailable = false;
                    ServerApiStatus = $"Server unavailable; parameter search was not run in the browser automatically ({ex.Message}). Select Browser only, or restart the server API.";
                    LastExecutionLabel = "none";
                    return;
                }
            }
            else
            {
                SearchResult = Model.FindBest(request);
                LastExecutionLabel = "browser";
            }

            if (SearchResult is not null)
            {
                StatusMessage = $"Search complete on {LastExecutionLabel}: {SearchResult.Candidates.Count:N0} candidates, best score {SearchResult.Best.CombinedScore:P2}.";
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            SearchRunning = false;
        }
    }

    private void UseBest()
    {
        if (SearchResult is null) return;
        ApplyParameters(SearchResult.Best.Parameters);
        _ = RunValidationAsync();
    }

    private async Task DetectServerApiAsync()
    {
        var candidates = new List<string?>();
        candidates.Add(Http.BaseAddress?.ToString().TrimEnd('/'));

        if (IsLocalAppHost())
        {
            candidates.Add("http://localhost:5003");
            candidates.Add("https://localhost:7275");
        }

        foreach (var candidate in candidates
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase))
        {
            try
            {
                using var client = new HttpClient { BaseAddress = new Uri(candidate! + "/") };
                using var response = await client.GetAsync("api/simulation/status");
                if (!response.IsSuccessStatusCode)
                {
                    continue;
                }

                ServerApiBaseAddress = candidate!;
                ServerApiAvailable = true;
                ServerApiStatus = $"Server API detected: {ServerApiBaseAddress}";
                return;
            }
            catch
            {
                // Browser-only mode remains available when the server host is absent.
            }
        }

        ServerApiAvailable = false;
        ServerApiBaseAddress = candidates.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? "";
        ServerApiStatus = "Server API not detected; browser-only mode is active.";
    }

    private bool ShouldUseServer()
    {
        return ExecutionMode switch
        {
            "Server" => true,
            "Browser" => false,
            _ => IsLocalAppHost() && ServerApiAvailable && !string.IsNullOrWhiteSpace(ServerApiBaseAddress)
        };
    }

    private bool IsLocalAppHost()
    {
        if (!Uri.TryCreate(Navigation.Uri, UriKind.Absolute, out var uri))
        {
            return false;
        }

        return uri.IsLoopback ||
            uri.Host.Equals("localhost", StringComparison.OrdinalIgnoreCase) ||
            uri.Host.Equals("127.0.0.1", StringComparison.OrdinalIgnoreCase) ||
            uri.Host.Equals("[::1]", StringComparison.OrdinalIgnoreCase);
    }

    private string BrowserOnlyStatus()
    {
        if (ExecutionMode == "Browser")
        {
            return "Browser-only mode selected.";
        }

        if (!IsLocalAppHost())
        {
            return "Auto selected browser mode for this deployed/static host.";
        }

        return ServerApiStatus ?? "Browser-only mode is active.";
    }

    private async Task<TResponse> PostServerAsync<TRequest, TResponse>(string relativeUrl, TRequest request)
    {
        if (string.IsNullOrWhiteSpace(ServerApiBaseAddress))
        {
            throw new InvalidOperationException("Server API address is empty.");
        }

        using var client = new HttpClient { BaseAddress = new Uri(ServerApiBaseAddress.TrimEnd('/') + "/") };
        using var response = await client.PostAsJsonAsync(relativeUrl, request);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<TResponse>()
            ?? throw new InvalidOperationException("Server API returned an empty response.");
    }

