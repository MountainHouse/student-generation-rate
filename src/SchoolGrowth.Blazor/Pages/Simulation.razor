    @foreach (var chartTool in ChartTools.Where(tool => IsToolActive(tool.Id)))
    {
    <ToolPanel Id="@chartTool.Id" Title="@chartTool.Title" CssClass="band tool-panel charts-tool" Style="@ToolStyle(chartTool.Id)"
               Collapsed="@IsToolCollapsed(chartTool.Id)" CanMoveUp="@CanMoveToolUp(chartTool.Id)" CanMoveDown="@CanMoveToolDown(chartTool.Id)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
        <TitleContent>
            @if (chartTool.EditingTitle)
            {
                <input class="tool-title-input" value="@chartTool.Title"
                       @oninput="args => chartTool.Title = args.Value?.ToString() ?? chartTool.Title"
                       @onblur="() => FinishChartTitleEdit(chartTool)"
                       @onkeydown="args => OnChartTitleKeyDown(chartTool, args)" />
            }
            else
            {
                <h2 class="tool-title-editable">
                    <button type="button" class="tool-title-button" title="Rename chart" @onclick="() => chartTool.EditingTitle = true">@chartTool.Title</button>
                    <button type="button" class="tool-title-edit-button" title="Rename chart" aria-label="Rename chart" @onclick="() => chartTool.EditingTitle = true">✎</button>
                </h2>
            }
        </TitleContent>
        <ChildContent>
        <div class="chart-box">
            <div class="chart-head">
                <h2>Trend</h2>
                <div class="chart-controls validation-chart-controls">
                    <select value="@chartTool.Measure" @onchange="args => OnChartMeasureChanged(chartTool, args)">
                        <option value="students">Students</option>
                        <option value="cohort">Student Cohort</option>
                        <option value="homes">Homes</option>
                        <option value="generation">Student Generation</option>
                        <option value="family">Family Profile</option>
                        <option value="turnover">Turnover</option>
                    </select>
                    <select value="@chartTool.Neighborhood" @onchange="args => OnChartNeighborhoodChanged(chartTool, args)">
                        @foreach (var neighborhood in ChartNeighborhoodOptions(chartTool))
                        {
                            <option value="@neighborhood">@FormatValidationNeighborhood(neighborhood)</option>
                        }
                    </select>
                    <select value="@chartTool.Density" @onchange="args => OnChartDensityChanged(chartTool, args)">
                        @foreach (var density in ValidationDensityOptions)
                        {
                            <option value="@density">@density</option>
                        }
                    </select>
                    <select value="@chartTool.Breakdown" @onchange="args => OnChartBreakdownChanged(chartTool, args)">
                        @foreach (var breakdown in ChartBreakdownOptions(chartTool))
                        {
                            <option value="@breakdown">@FormatChartBreakdown(chartTool, breakdown)</option>
                        }
                    </select>
                    <select value="@chartTool.ValueMode" @onchange="args => OnChartValueModeChanged(chartTool, args)">
                        @foreach (var mode in ChartValueModeOptions(chartTool))
                        {
                            <option value="@mode.Key">@mode.Label</option>
                        }
                    </select>
                    <button type="button" class="icon-button compact-icon-button" title="Pin current graph" @onclick="() => PinChartSelection(chartTool)">+</button>
                </div>
            </div>
            <div class="chart-panel-layout">
            <div class="chart-canvas">
            @{
                var chartSeries = ChartSeries(chartTool);
            }
            <svg id="@ChartSvgElementId(chartTool)" viewBox="0 0 920 300" role="img">
                @foreach (var tick in ChartYTicks(chartTool))
                {
                    <line x1="60" y1="@tick.Y" x2="860" y2="@tick.Y" class="chart-grid" />
                    <SvgText X="50" Y="@(tick.Y + 4)" Anchor="end" Label="@tick.Label" />
                }
                <line x1="60" y1="260" x2="860" y2="260" class="chart-axis" />
                <line x1="60" y1="40" x2="60" y2="260" class="chart-axis" />
                @foreach (var tick in XTicks)
                {
                    <line x1="@tick.X" y1="260" x2="@tick.X" y2="266" class="chart-axis" />
                    <SvgText X="@tick.X" Y="284" Anchor="middle" Label="@tick.Label" />
                }
                @foreach (var series in chartSeries)
                {
                    var twoSigmaBandPoints = ChartBandPoints(chartTool, series, sigmaMultiplier: 2);
                    var oneSigmaBandPoints = ChartBandPoints(chartTool, series, sigmaMultiplier: 1);
                    @if (!string.IsNullOrWhiteSpace(twoSigmaBandPoints))
                    {
                        <polygon points="@twoSigmaBandPoints" fill="@series.Color" opacity="0.4" stroke="none" />
                    }
                    @if (!string.IsNullOrWhiteSpace(oneSigmaBandPoints))
                    {
                        <polygon points="@oneSigmaBandPoints" fill="@series.Color" opacity="0.6" stroke="none" />
                    }
                    <polyline points="@ChartPoints(chartTool, series.Values)" fill="none" stroke="@series.Color" stroke-width="4" stroke-dasharray="@series.DashArray" />
                }
                <rect x="0" y="0" width="920" height="300" class="chart-pointer-capture" />
                <line x1="60" y1="40" x2="60" y2="260" class="chart-hover-line js-chart-hover-line" style="display:none" />
                @foreach (var series in chartSeries)
                {
                    <circle cx="60" cy="260" r="4" fill="@series.Color" class="chart-hover-dot js-chart-hover-dot" data-y-values="@ChartYValuesJson(series.Values, value => ChartYForValue(chartTool, value))" style="display:none" />
                }
            </svg>
            </div>
            <aside class="chart-side-legend">
            <div class="inline-legend validation-legend chart-tool-legend">
                <span class="legend-hover-year legend-hover-year-empty js-chart-hover-year" data-years="@ChartYearsJson">
                    Year
                </span>
                @foreach (var group in ChartLegendGroups(chartTool))
                {
                    <span class="validation-legend-group">
                        @if (group.PinnedId.HasValue)
                        {
                            <button type="button" class="legend-remove" title="Remove line" @onclick="() => RemoveChartSelection(chartTool, group.PinnedId.Value)">x</button>
                        }
                        else
                        {
                            <span class="legend-remove-spacer" aria-hidden="true"></span>
                        }
                        <strong>@group.Label</strong>
                        @foreach (var series in group.Series)
                        {
                            <span style="@($"--legend-value-width:{ChartLegendReserveWidthCh(series):0.#}ch")"><i style="@($"background:{series.Color}")"></i><span class="js-chart-hover-label" data-default-label="@series.Label" data-labels="@ChartLegendLabelsJson(series)">@series.Label</span></span>
                        }
                    </span>
                }
            </div>
            </aside>
            </div>
        </div>
        </ChildContent>
    </ToolPanel>
    }

