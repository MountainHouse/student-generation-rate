    private bool TrackCustomPreset()
    {
        var current = CurrentParameters();
        if (SelectedPresetName.Equals(CustomPresetName, StringComparison.OrdinalIgnoreCase))
        {
            CustomParameters = current;
            return false;
        }

        var selectedPreset = ParameterPresets
            .FirstOrDefault(item => item.Name.Equals(SelectedPresetName, StringComparison.OrdinalIgnoreCase));
        if (selectedPreset is null || ParametersMatch(current, selectedPreset.Parameters))
        {
            return false;
        }

        CustomParameters = current;
        SelectedPresetName = CustomPresetName;
        return true;
    }

    private static bool ParametersMatch(MonteCarloParameters left, MonteCarloParameters right) => left.Equals(right);

    private async Task RunValidationAsync()
    {
        await RunValidationAsync(preserveScroll: false);
    }

    private async Task RunScenarioValidationAsync()
    {
        await RunValidationAsync(preserveScroll: false);
    }

    private async Task RunValidationAsync(bool preserveScroll)
    {
        if (Model is null) return;
        ValidationDebounce?.Cancel();
        ValidationDebounce?.Dispose();
        var debounce = new CancellationTokenSource();
        ValidationDebounce = debounce;
        var scrollPosition = preserveScroll
            ? await CaptureScrollPositionAsync()
            : null;

        try
        {
            await Task.Delay(600, debounce.Token);
            if (!debounce.IsCancellationRequested)
            {
                await ExecuteValidationAsync(scrollPosition);
            }
        }
        catch (TaskCanceledException)
        {
            // A newer edit superseded this validation request.
        }
    }

    private async Task ExecuteValidationAsync(ScrollPosition? scrollPosition = null)
    {
        if (Model is null) return;
        if (ValidationRunning)
        {
            PendingValidation = true;
            return;
        }

        ValidationRunning = true;
        do
        {
            PendingValidation = false;
            var executionLabel = ShouldUseServer() ? "server" : "browser";
            StatusMessage = $"Running simulation validation on {executionLabel}: {Runs:N0} runs...";
            await InvokeAsync(StateHasChanged);
            await Task.Yield();

            var stopwatch = System.Diagnostics.Stopwatch.StartNew();
            try
            {
                var ran = await RunValidationCoreAsync();
                stopwatch.Stop();
                var elapsed = FormatElapsed(stopwatch.Elapsed);
                StatusMessage = ran
                    ? $"Validation complete on {LastExecutionLabel}: {Runs:N0} runs in {elapsed}, score {Result?.CombinedScore:P2}. {ServerApiStatus}"
                    : $"{ServerApiStatus} ({elapsed})";
            }
            catch (Exception ex)
            {
                stopwatch.Stop();
                StatusMessage = $"Validation failed after {FormatElapsed(stopwatch.Elapsed)}: {ex.Message}";
            }
            await InvokeAsync(StateHasChanged);
            await RestoreScrollPositionAsync(scrollPosition);
        }
        while (PendingValidation);

        ValidationRunning = false;
    }

    private async Task<ScrollPosition?> CaptureScrollPositionAsync()
