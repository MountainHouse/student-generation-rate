    private async Task LoadPresetAsync(ChangeEventArgs args)
    {
        var name = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(name)) return;

        var preset = PresetOptions.FirstOrDefault(item => item.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
        if (preset is null) return;

        SelectedPresetName = preset.Name;
        ApplyParameters(preset.Parameters);
