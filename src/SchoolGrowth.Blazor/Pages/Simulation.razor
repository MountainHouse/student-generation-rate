        public double Homes { get; set; } = homes;
    }

    private sealed class ChartToolState(string id, string title)
    {
        public string Id { get; } = id;
        public string Title { get; set; } = title;
        public string Measure { get; set; } = "students";
        public string Neighborhood { get; set; } = AllNeighborhood;
        public string Density { get; set; } = AllDensity;
        public string Breakdown { get; set; } = "Total";
        public string ValueMode { get; set; } = "value";
        public List<ChartPinnedSelection> PinnedSelections { get; } = [];
        public int NextPinnedSelectionId { get; set; } = 1;
        public string? CacheKey { get; set; }
        public ValidationChartCache? CacheValue { get; set; }
        public Dictionary<string, SegmentStats> SegmentStatsCache { get; } = new(StringComparer.OrdinalIgnoreCase);
        public int? HoverIndex { get; set; }
        public bool EditingTitle { get; set; }
    }

    private sealed record ValidationChartLine(
        string Label,
        string Color,
        IReadOnlyList<double?> Values,
        Func<double, string> Formatter,
        string DashArray,
        string HoverLabel = "",
        IReadOnlyList<double?>? StandardDeviations = null,
        int Runs = 0,
        IReadOnlyList<double?>? OneSigmaLowValues = null,
        IReadOnlyList<double?>? OneSigmaHighValues = null,
        IReadOnlyList<double?>? TwoSigmaLowValues = null,
        IReadOnlyList<double?>? TwoSigmaHighValues = null);

    private sealed record ValidationPinnedSelection(
        int Id,
        string Key,
        string Label,
        IReadOnlyList<ValidationChartLine> Series);

    private sealed record ValidationLegendGroup(
        int? PinnedId,
        string Label,
        IReadOnlyList<ValidationChartLine> Series);

    private sealed record ValidationChartCache(
        IReadOnlyList<double?> ModeledValues,
        IReadOnlyList<double?> ReferenceValues,
        IReadOnlyList<double?> AbsoluteErrorValues,
        IReadOnlyList<double?> PercentErrorValues,
        IReadOnlyList<ValidationChartLine> Series,
        IReadOnlyList<double> Numbers,
        double Max,
        double Min,
        double Span);

    private sealed record ValidationValueModeOption(string Key, string Label);

    private sealed record SegmentStats(
        double TotalHomes,
        Dictionary<string, double> Grades,
        double FamiliesWithZeroChildren,
        double FamiliesWithOneChild,
        double FamiliesWithTwoChildren,
        double FamiliesWithThreeChildren,
        double FamiliesWithFourPlusChildren,
        double TurnoverEvents,
        double AverageLongevityBeforeTurnover);

    public async ValueTask DisposeAsync()
    {
        ValidationHoverReference?.Dispose();
        ValidationDebounce?.Cancel();
        ValidationDebounce?.Dispose();
        await ValueTask.CompletedTask;
    }

    private sealed record SimulationInfoRow(
        string Group,
        string Metric,
        Func<MonteCarloSimulationYearInfo, MarkupString> Value,
        Func<MonteCarloSimulationYearInfo, double?> ChartValue,
        Func<MonteCarloSimulationYearInfo, double?>? ReferenceValue,
        Func<double, string> Formatter)
    {
        public string Key => $"{Group}|{Metric}";
    }

    private sealed record DensityEffectRow(
        string Label,
        DensityFactorBinding FirstFactor,
        DensityFactorBinding SecondFactor,
        DensityFactorBinding ThirdFactor,
        IReadOnlyList<DensityChildEffect> Children);

    private sealed record DensityChildEffect(int ChildNumber, double MoveInShare, double BirthProbability);

    private sealed class DensityFactorBinding(Func<double> getter, Action<double> setter)
    {
        public double Value
        {
            get => getter();
            set => setter(value);
        }
    }
}
