    }

    private async Task LoadSavedLayoutAsync()
    {
        try
        {
            var years = await Js.InvokeAsync<SavedYearsState?>("schoolGrowthStorage.getJson", YearsStorageKey);
            if (years is not null)
            {
                StartYear = Math.Clamp(years.StartYear, MinStartYear, MaxSimulationEndYear);
                EndYear = Math.Clamp(years.EndYear, StartYear, MaxSimulationEndYear);
                SelectedComparisonYear = EndYear;
            }

            var layout = await Js.InvokeAsync<SavedSimulationLayout?>("schoolGrowthStorage.getJson", LayoutStorageKey);
            if (layout is not null)
            {
                ChartTools.Clear();
                NextChartToolNumber = 1;
                foreach (var savedChart in layout.ChartTools ?? [])
                {
                    CreateChartTool(savedChart, activate: false);
                }

                var validToolIds = ToolDefinitions
                    .Select(tool => tool.Id)
                    .Concat(ChartTools.Select(tool => tool.Id))
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
                var activeIds = layout.ActiveToolIds
                    .Where(validToolIds.Contains)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList();
                ActiveToolIds = activeIds.Count > 0 ? activeIds : DefaultActiveToolIds.ToList();

                CollapsedToolIds = layout.CollapsedToolIds
                    .Where(ActiveToolIds.Contains)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);

                ShowIncreaseFromStart = layout.ShowIncreaseFromStart;
                ShowIncreaseFromStartPercent = layout.ShowIncreaseFromStartPercent;
                ShowIncreaseFromPrevious = layout.ShowIncreaseFromPrevious;
                ShowIncreaseFromPreviousPercent = layout.ShowIncreaseFromPreviousPercent;
                ValidationMeasure = string.IsNullOrWhiteSpace(layout.ValidationMeasure) ? "students" : layout.ValidationMeasure;
                ValidationNeighborhood = string.IsNullOrWhiteSpace(layout.ValidationNeighborhood) ? AllNeighborhood : layout.ValidationNeighborhood;
                ValidationDensity = string.IsNullOrWhiteSpace(layout.ValidationDensity) ? AllDensity : layout.ValidationDensity;
                ValidationBreakdown = string.IsNullOrWhiteSpace(layout.ValidationBreakdown) ? "Total" : layout.ValidationBreakdown;
                ValidationValueMode = string.IsNullOrWhiteSpace(layout.ValidationValueMode) ? "value" : layout.ValidationValueMode;
                ScenarioRows.Clear();
                foreach (var row in layout.ScenarioHomes ?? [])
                {
                    ScenarioRows.Add(new ScenarioHomeInput(row.Neighborhood, row.Density, row.Year, row.Homes));
                }

                SelectedSimulationInfoRows.Clear();
                foreach (var key in layout.SelectedSimulationInfoRows)
                {
                    SelectedSimulationInfoRows.Add(key);
                }
            }
        }
        catch
        {
            // Saved browser state is a convenience; ignore corrupt or unavailable storage.
        }
        finally
        {
            SavedLayoutLoaded = true;
        }
    }

