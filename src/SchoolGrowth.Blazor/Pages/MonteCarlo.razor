@page "/monte-carlo"
@inject HttpClient Http

<PageTitle>Monte Carlo Model</PageTitle>

<header class="topbar">
    <div>
        <h1>Monte Carlo Model</h1>
        <p>Validate a household-style simulation against grid and grade reference data.</p>
    </div>
    <div class="top-actions">
        <a class="nav-button secondary" href="">Simulator</a>
        <a class="nav-button secondary" href="validation">Model Validation</a>
    </div>
</header>

@if (LoadError is not null)
{
    <section class="band">
        <strong>@LoadError</strong>
    </section>
}
else if (Data is null)
{
    <section class="band">Loading Monte Carlo model...</section>
}
else
{
    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <section class="band status-band">
            <strong>@StatusMessage</strong>
        </section>
    }

    <section class="band parameter-group">
        <h2>Validation Run</h2>
        <div class="controls monte-controls">
        <label>
            <span>Start year</span>
            <input type="number" min="@MinStartYear" max="@MaxSimulationEndYear" @bind="StartYear" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>End year</span>
            <input type="number" min="@StartYear" max="@MaxSimulationEndYear" @bind="EndYear" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Runs</span>
            <input type="number" min="10" max="10000" step="10" @bind="Runs" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Seed</span>
            <input type="number" @bind="Seed" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Execution</span>
            <select @bind="ExecutionMode" @bind:after="RunValidationAsync">
                <option value="Auto">Auto server preferred</option>
                <option value="Server">Server API</option>
                <option value="Browser">Browser only</option>
            </select>
        </label>
        <label>
            <span>Server API</span>
            <input @bind="ServerApiBaseAddress" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Grade smoothing window</span>
            <input type="number" min="0" max="4" step="1" @bind="GradeSmoothingWindow" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Total score weight</span>
            <input type="number" min="0" step="0.1" @bind="ScoreTotalWeight" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Grid score weight</span>
            <input type="number" min="0" step="0.1" @bind="ScoreGridWeight" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Grade score weight</span>
            <input type="number" min="0" step="0.1" @bind="ScoreGradeWeight" @bind:after="RunValidationAsync" />
        </label>
        </div>
    </section>

    <section class="band parameter-group">
        <h2>Household Turnover and Exit</h2>
        <div class="controls monte-controls">
        <label>
            <span>Ownership change</span>
            <input type="number" min="0" max="1" step="0.005" @bind="OwnershipChangeProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>0 child share</span>
            <input type="number" min="0" max="1" step="0.005" @bind="MoveInZeroChildShare" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>1 child share</span>
            <input type="number" min="0" max="1" step="0.005" @bind="MoveInOneChildShare" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>2 child share</span>
            <input type="number" min="0" max="1" step="0.005" @bind="MoveInTwoChildShare" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>3 child share</span>
            <input type="number" min="0" max="1" step="0.005" @bind="MoveInThreeChildShare" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>4+ child share</span>
            <input type="number" min="0" max="1" step="0.005" @bind="MoveInFourPlusChildShare" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Student exit</span>
            <input type="number" min="0" max="1" step="0.005" @bind="StudentExitProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>TK-8 exit</span>
            <input type="number" min="0" max="1" step="0.005" @bind="Tk8ExitProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>High school exit</span>
            <input type="number" min="0" max="1" step="0.005" @bind="HighSchoolExitProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Special ed exit</span>
            <input type="number" min="0" max="1" step="0.005" @bind="SpecialExitProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Special ed probability</span>
            <input type="number" min="0" max="1" step="0.001" @bind="SpecialEducationProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Same school year</span>
            <input type="number" min="0" max="1" step="0.005" @bind="SameSchoolYearProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Max parallelism</span>
            <input type="number" min="0" step="1" @bind="MaxDegreeOfParallelism" @bind:after="RunValidationAsync" />
        </label>
        </div>
    </section>

    <section class="band parameter-group">
        <h2>Move-In Age Weights</h2>
        <div class="controls monte-controls">
        <label>
            <span>Preschool weight</span>
            <input type="number" min="0" step="0.01" @bind="MoveInPreschoolWeight" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>TK/K weight</span>
            <input type="number" min="0" step="0.01" @bind="MoveInTkKWeight" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Elementary weight</span>
            <input type="number" min="0" step="0.01" @bind="MoveInElementaryWeight" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Middle weight</span>
            <input type="number" min="0" step="0.01" @bind="MoveInMiddleWeight" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>High weight</span>
            <input type="number" min="0" step="0.01" @bind="MoveInHighWeight" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Post-school weight</span>
            <input type="number" min="0" step="0.01" @bind="MoveInPostSchoolWeight" @bind:after="RunValidationAsync" />
        </label>
        </div>
    </section>

    <section class="band parameter-group">
        <h2>Birth/New Child Rates</h2>
        <div class="controls monte-controls">
        <label>
            <span>1st birth / year</span>
            <input type="number" min="0" max="1" step="0.001" @bind="AnnualFirstNewChildProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>2nd birth / year</span>
            <input type="number" min="0" max="1" step="0.001" @bind="AnnualSecondNewChildProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>3rd birth / year</span>
            <input type="number" min="0" max="1" step="0.001" @bind="AnnualThirdNewChildProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>4th+ birth / year</span>
            <input type="number" min="0" max="1" step="0.001" @bind="AnnualFourthPlusNewChildProbability" @bind:after="RunValidationAsync" />
        </label>
        </div>
    </section>

    <section class="band parameter-group">
        <h2>Density Factors</h2>
        <div class="controls monte-controls">
        <label>
            <span>Low/medium factor</span>
            <input type="number" min="0" step="0.01" @bind="DensityLowMediumFactor" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>Medium-high factor</span>
            <input type="number" min="0" step="0.01" @bind="DensityMediumHighFactor" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>High factor</span>
            <input type="number" min="0" step="0.01" @bind="DensityHighFactor" @bind:after="RunValidationAsync" />
        </label>
        </div>
        <div class="density-factor-table">
            <table>
                <thead>
                    <tr>
                        <th>Density</th>
                        <th>1st child</th>
                        <th>2nd child</th>
                        <th>3rd child</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Low/Medium</td>
                        <td><input type="number" min="0" step="0.01" @bind="DensityLowMediumFirstChildFactor" @bind:after="RunValidationAsync" /></td>
                        <td><input type="number" min="0" step="0.01" @bind="DensityLowMediumSecondChildFactor" @bind:after="RunValidationAsync" /></td>
                        <td><input type="number" min="0" step="0.01" @bind="DensityLowMediumThirdChildFactor" @bind:after="RunValidationAsync" /></td>
                    </tr>
                    <tr>
                        <td>Medium-High</td>
                        <td><input type="number" min="0" step="0.01" @bind="DensityMediumHighFirstChildFactor" @bind:after="RunValidationAsync" /></td>
                        <td><input type="number" min="0" step="0.01" @bind="DensityMediumHighSecondChildFactor" @bind:after="RunValidationAsync" /></td>
                        <td><input type="number" min="0" step="0.01" @bind="DensityMediumHighThirdChildFactor" @bind:after="RunValidationAsync" /></td>
                    </tr>
                    <tr>
                        <td>High</td>
                        <td><input type="number" min="0" step="0.01" @bind="DensityHighFirstChildFactor" @bind:after="RunValidationAsync" /></td>
                        <td><input type="number" min="0" step="0.01" @bind="DensityHighSecondChildFactor" @bind:after="RunValidationAsync" /></td>
                        <td><input type="number" min="0" step="0.01" @bind="DensityHighThirdChildFactor" @bind:after="RunValidationAsync" /></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    @if (Result is null)
    {
        <section class="band">Choose parameters or wait for the first validation run.</section>
    }
    else
    {
    <section class="band charts">
        <div class="chart-box">
            <h2>Actual vs Monte Carlo Grid Total</h2>
            <svg viewBox="0 0 920 300" role="img" @onmouseleave="() => TotalChartHoverIndex = null">
                @foreach (var tick in YTicks)
                {
                    <line x1="60" y1="@tick.Y" x2="860" y2="@tick.Y" class="chart-grid" />
                    <SvgText X="50" Y="@(tick.Y + 4)" Anchor="end" Label="@tick.Label" />
                }
                <line x1="60" y1="260" x2="860" y2="260" class="chart-axis" />
                <line x1="60" y1="40" x2="60" y2="260" class="chart-axis" />
                @foreach (var tick in XTicks)
                {
                    <line x1="@tick.X" y1="260" x2="@tick.X" y2="266" class="chart-axis" />
                    <SvgText X="@tick.X" Y="284" Anchor="middle" Label="@tick.Label" />
                }
                <polyline points="@ActualChartPoints" fill="none" stroke="#0f766e" stroke-width="4" />
                <polyline points="@ModeledChartPoints" fill="none" stroke="#b45309" stroke-width="4" />
                @if (TotalChartHoverIndex.HasValue)
                {
                    <line x1="@TotalHoverX" y1="40" x2="@TotalHoverX" y2="260" class="chart-hover-line" />
                    <rect x="@TotalHoverYearLabelX" y="44" width="58" height="20" rx="4" class="chart-hover-label-bg" />
                    <SvgText X="@(TotalHoverYearLabelX + 29)" Y="58" Anchor="middle" Label="@Result.Comparisons[TotalChartHoverIndex.Value].Year.ToString()" />
                    @foreach (var marker in TotalHoverMarkers)
                    {
                        <circle cx="@marker.X" cy="@marker.Y" r="4" fill="@marker.Color" class="chart-hover-dot" />
                    }
                    <rect x="@TotalHoverPanelX" y="@TotalHoverPanelY" width="180" height="48" rx="5" class="chart-hover-label-bg" />
                    @foreach (var item in TotalHoverMarkers.Select((marker, index) => new { marker, index }))
                    {
                        <circle cx="@(TotalHoverPanelX + 10)" cy="@(TotalHoverPanelY + 17 + item.index * 17)" r="3" fill="@item.marker.Color" class="chart-hover-dot" />
                        <SvgText X="@(TotalHoverPanelX + 18)" Y="@(TotalHoverPanelY + 21 + item.index * 17)" Anchor="start" Label="@item.marker.Label" />
                    }
                }
                @foreach (var zone in TotalHoverZones)
                {
                    <rect x="@zone.X" y="40" width="@zone.Width" height="220" fill="transparent" class="chart-hover-zone"
                          @onmouseover="() => TotalChartHoverIndex = zone.Index"
                          @onfocus="() => TotalChartHoverIndex = zone.Index" />
                }
            </svg>
            <div class="inline-legend">
                <span><i style="background:#0f766e"></i>Actual</span>
                <span><i style="background:#b45309"></i>Monte Carlo mean</span>
            </div>
        </div>
        <div class="chart-box">
            <h2>Validation Error</h2>
            <dl>
                <dt>Total MAE</dt>
                <dd>@Result.GridMeanAbsoluteError.ToString("N0")</dd>
                <dt>Total MAPE</dt>
                <dd>@Result.GridMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>Grid/year MAE</dt>
                <dd>@Result.GridLevelMeanAbsoluteError.ToString("N1")</dd>
                <dt>Grid/year MAPE</dt>
                <dd>@Result.GridLevelMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>Grade total MAE</dt>
                <dd>@Result.GradeMeanAbsoluteError.ToString("N0")</dd>
                <dt>Grade total MAPE</dt>
                <dd>@Result.GradeMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>Grade/year MAE</dt>
                <dd>@Result.GradeLevelMeanAbsoluteError.ToString("N1")</dd>
                <dt>Grade/year MAPE</dt>
                <dd>@Result.GradeLevelMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>Combined score</dt>
                <dd>@Result.CombinedScore.ToString("P2")</dd>
            </dl>
        </div>
    </section>

    <section class="band metric-options">
        <h2>Table Details</h2>
        <label>
            <input type="checkbox" @bind="ShowIncreaseFromStart" />
            <span>Increase from start</span>
        </label>
        <label>
            <input type="checkbox" @bind="ShowIncreaseFromStartPercent" />
            <span>Increase from start %</span>
        </label>
        <label>
            <input type="checkbox" @bind="ShowIncreaseFromPrevious" />
            <span>Increase from previous year</span>
        </label>
        <label>
            <input type="checkbox" @bind="ShowIncreaseFromPreviousPercent" />
            <span>Increase from previous year %</span>
        </label>
    </section>

    <CohortProgressTable Title="Monte Carlo Progressing Cohorts" Cohorts="MonteCarloProgressingCohorts" Projection="MonteCarloModeledProjection"
                         ReferenceProjection="MonteCarloReferenceProjection"
                         ProgressionGrades="VisibleCohortGrades"
                         ShowIncreaseFromStart="ShowIncreaseFromStart"
                         ShowIncreaseFromStartPercent="ShowIncreaseFromStartPercent"
                         ShowIncreaseFromPrevious="ShowIncreaseFromPrevious"
                         ShowIncreaseFromPreviousPercent="ShowIncreaseFromPreviousPercent" />
    <ProjectionTable Title="Monte Carlo Grades" Names="VisibleGradeOrder" Projection="MonteCarloModeledProjection" ValueSelector="GradeValue"
                     ReferenceProjection="MonteCarloReferenceProjection"
                     ReferenceValueSelector="GradeValue"
                     Subtotals="GradeSubtotals"
                     ShowIncreaseFromStart="ShowIncreaseFromStart"
                     ShowIncreaseFromStartPercent="ShowIncreaseFromStartPercent"
                     ShowIncreaseFromPrevious="ShowIncreaseFromPrevious"
                     ShowIncreaseFromPreviousPercent="ShowIncreaseFromPreviousPercent" />
    <ProjectionTable Title="Monte Carlo Grid Totals" Names="MonteCarloGridNames" Projection="MonteCarloModeledProjection" ValueSelector="GridValue"
                     ReferenceProjection="MonteCarloReferenceProjection"
                     ReferenceValueSelector="GridValue"
                     ShowIncreaseFromStart="ShowIncreaseFromStart"
                     ShowIncreaseFromStartPercent="ShowIncreaseFromStartPercent"
                     ShowIncreaseFromPrevious="ShowIncreaseFromPrevious"
                     ShowIncreaseFromPreviousPercent="ShowIncreaseFromPreviousPercent" />

    <section class="band split">
        <div>
            <div class="section-head">
                <h2>Parameter Search</h2>
                <button @onclick="FindBest" disabled="@SearchRunning">@(SearchRunning ? "Searching..." : "Find Best")</button>
            </div>
            <div class="controls search-controls">
                <label>
                    <span>Runs per candidate</span>
                    <input type="number" min="10" max="2000" step="10" @bind="SearchRuns" />
                </label>
                <label>
                    <span>Turnover candidates</span>
                    <input @bind="OwnershipCandidatesText" />
                </label>
                <label>
                    <span>0 child candidates</span>
                    <input @bind="ZeroChildCandidatesText" />
                </label>
                <label>
                    <span>1 child candidates</span>
                    <input @bind="OneChildCandidatesText" />
                </label>
                <label>
                    <span>2 child candidates</span>
                    <input @bind="TwoChildCandidatesText" />
                </label>
                <label>
                    <span>3 child candidates</span>
                    <input @bind="ThreeChildCandidatesText" />
                </label>
                <label>
                    <span>4+ child candidates</span>
                    <input @bind="FourPlusChildCandidatesText" />
                </label>
                <label>
                    <span>Exit candidates</span>
                    <input @bind="ExitCandidatesText" />
                </label>
            </div>
        </div>
        <aside class="panel">
            <h2>Best Candidate</h2>
            @if (SearchResult is null)
            {
                <p>Run parameter search to compare candidate probabilities.</p>
            }
            else
            {
                <dl>
                    <dt>Score</dt>
                    <dd>@SearchResult.Best.CombinedScore.ToString("P2")</dd>
                    <dt>Turnover</dt>
                    <dd>@SearchResult.Best.Parameters.OwnershipChangeProbability.ToString("P1")</dd>
                    <dt>Move-in children</dt>
                    <dd>@SearchResult.Best.Parameters.MoveInZeroChildShare.ToString("P1") / @SearchResult.Best.Parameters.MoveInOneChildShare.ToString("P1") / @SearchResult.Best.Parameters.MoveInTwoChildShare.ToString("P1") / @SearchResult.Best.Parameters.MoveInThreeChildShare.ToString("P1") / @SearchResult.Best.Parameters.MoveInFourPlusChildShare.ToString("P1")</dd>
                    <dt>Exit</dt>
                    <dd>@SearchResult.Best.Parameters.StudentExitProbability.ToString("P1")</dd>
                    <dt>Special ed probability</dt>
                    <dd>@SearchResult.Best.Parameters.SpecialEducationProbability.ToString("P1")</dd>
                    <dt>Births/year</dt>
                    <dd>@SearchResult.Best.Parameters.AnnualFirstNewChildProbability.ToString("P1") / @SearchResult.Best.Parameters.AnnualSecondNewChildProbability.ToString("P1") / @SearchResult.Best.Parameters.AnnualThirdNewChildProbability.ToString("P1") / @SearchResult.Best.Parameters.AnnualFourthPlusNewChildProbability.ToString("P1")</dd>
                    <dt>Non-student weights</dt>
                    <dd>@SearchResult.Best.Parameters.MoveInPreschoolWeight.ToString("0.##") pre-school / @SearchResult.Best.Parameters.MoveInPostSchoolWeight.ToString("0.##") post-school</dd>
                </dl>
                <button class="secondary" @onclick="UseBest">Use Best</button>
            }
        </aside>
    </section>

    <section class="band">
        <h2>Modeled vs Reference Totals</h2>
        <div class="table-viz">
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Year</th>
                            <th>Actual Grid</th>
                            <th>Modeled Grid</th>
                            <th>Grid Error</th>
                            <th>Grid Error %</th>
                            <th>Grid/Year Error %</th>
                            <th>Adjusted Grade</th>
                            <th>Modeled Grade</th>
                            <th>Grade Error</th>
                            <th>Grade Error %</th>
                            <th>Grade/Year Error %</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var comparison in Result.Comparisons)
                        {
                            <tr>
                                <td>@comparison.Year</td>
                                <td>@comparison.ActualGridTotal.ToString("N0")</td>
                                <td>@comparison.ModeledGridTotal.ToString("N0")</td>
                                <td>@comparison.GridError.ToString("+#,##0;-#,##0;0")</td>
                                <td>@comparison.GridAbsolutePercentageError.ToString("P1")</td>
                                <td>@comparison.GridLevelMeanAbsolutePercentageError.ToString("P1")</td>
                                <td>@comparison.ActualGradeTotal.ToString("N0")</td>
                                <td>@comparison.ModeledGradeTotal.ToString("N0")</td>
                                <td>@comparison.GradeError.ToString("+#,##0;-#,##0;0")</td>
                                <td>@comparison.GradeAbsolutePercentageError.ToString("P1")</td>
                                <td>@comparison.GradeLevelMeanAbsolutePercentageError.ToString("P1")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <aside class="table-chart">
                <div class="chart-head">
                    <h2>Comparison Trend</h2>
                    <div class="chart-controls">
                        <select @bind="ComparisonChartMode">
                            <option value="total">Total</option>
                            <option value="grid">Grid</option>
                            <option value="grade">Grade</option>
                        </select>
                        <select @bind="ComparisonChartEntity">
                            @foreach (var entity in ComparisonChartEntities)
                            {
                                <option value="@entity">@entity</option>
                            }
                        </select>
                    </div>
                </div>
                <svg viewBox="0 0 920 300" role="img">
                    @foreach (var tick in ComparisonYTicks)
                    {
                        <line x1="60" y1="@tick.Y" x2="860" y2="@tick.Y" class="chart-grid" />
                        <SvgText X="50" Y="@(tick.Y + 4)" Anchor="end" Label="@tick.Label" />
                    }
                    <line x1="60" y1="260" x2="860" y2="260" class="chart-axis" />
                    <line x1="60" y1="40" x2="60" y2="260" class="chart-axis" />
                    @foreach (var tick in ComparisonXTicks)
                    {
                        <line x1="@tick.X" y1="260" x2="@tick.X" y2="266" class="chart-axis" />
                        <SvgText X="@tick.X" Y="284" Anchor="middle" Label="@tick.Label" />
                    }
                    <polyline points="@ComparisonActualChartPoints" fill="none" stroke="#0f766e" stroke-width="4" />
                    <polyline points="@ComparisonModeledChartPoints" fill="none" stroke="#b45309" stroke-width="4" />
                </svg>
                <div class="inline-legend">
                    <span><i style="background:#0f766e"></i>Reference</span>
                    <span><i style="background:#b45309"></i>Modeled</span>
                </div>
            </aside>
        </div>
    </section>

    <section class="band">
        <h2>Grid Detail for @SelectedComparisonYear</h2>
        <label class="compact-select">
            <span>Comparison year</span>
            <select @bind="SelectedComparisonYear">
                @foreach (var comparison in Result.Comparisons)
                {
                    <option value="@comparison.Year">@comparison.Year</option>
                }
            </select>
        </label>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Grid</th>
                        <th>Actual</th>
                        <th>Modeled</th>
                        <th>Error</th>
                        <th>Error %</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in SelectedGridComparisons)
                    {
                        <tr>
                            <td>@row.Grid</td>
                            <td>@FormatNullable(row.Actual)</td>
                            <td>@row.Modeled.ToString("N0")</td>
                            <td>@(row.Actual.HasValue ? (row.Modeled - row.Actual.Value).ToString("+#,##0;-#,##0;0") : "n/a")</td>
                            <td>@(row.Actual is > 0 ? (Math.Abs(row.Modeled - row.Actual.Value) / row.Actual.Value).ToString("P1") : "n/a")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="band">
        <h2>Grade Detail for @SelectedComparisonYear</h2>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Grade</th>
                        <th>Actual Raw</th>
                        <th>Adjusted Actual</th>
                        <th>Modeled</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in SelectedGradeComparisons)
                    {
                        <tr>
                            <td>@row.Grade</td>
                            <td>@FormatNullable(row.Actual)</td>
                            <td>@row.AdjustedActual.ToString("N0")</td>
                            <td>@row.Modeled.ToString("N0")</td>
                            <td>@((row.Modeled - row.AdjustedActual).ToString("+#,##0;-#,##0;0"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="band formulas">
        <h2>Monte Carlo Rules</h2>
        <p><strong>Baseline:</strong> homes are back-played from construction year into <code>start year - 1</code>, so old homes may already have changed households before the validation window starts.</p>
        <p><strong>Special grids:</strong> Lammersville and Inter-Districts use fair grade shares; MHESD uses grades 9-12 only.</p>
        <p><strong>Ownership change:</strong> each home has a yearly chance to replace its household, with lower early-year turnover and forced turnover by year 50.</p>
        <p><strong>Children at move-in:</strong> the model draws a household child count from explicit 0, 1, 2, 3, and 4+ child shares. Move-in age weights place those children into preschool, TK/K, elementary, middle, high school, or post-school bands.</p>
        <p><strong>Density:</strong> low/medium, medium-high, and high density homes apply common density factors plus child-number factors for 1st, 2nd, and 3rd children.</p>
        <p><strong>Special education:</strong> every child has a probability of receiving a special education attribute. Special education children keep their underlying age/grade for aging, but are counted in the Sp. Ed. reporting bucket while enrolled.</p>
        <p><strong>Build timing:</strong> each newly built home joins either the same school year or the next school year, controlled by the same-school-year probability.</p>
        <p><strong>New children after move-in:</strong> annual 1st, 2nd, 3rd, and 4th+ child probabilities control births/new preschool children after the household arrives.</p>
        <p><strong>Student exit:</strong> each student has a yearly probability to leave district enrollment without a home ownership change; TK-8, high school, and special education exits can be adjusted separately.</p>
        <p><strong>Validation:</strong> results are averaged over all runs and compared year-over-year against total enrollment, grid spread, and smoothed grade-by-grade error. TK is excluded from grade validation.</p>
    </section>
    }
