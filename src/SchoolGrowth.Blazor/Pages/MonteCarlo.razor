    private static ProjectionYear ToProjectionYear(
        int year,
        Dictionary<string, double> grades,
        Dictionary<string, double> gridTotals,
        double total)
    {
        return new ProjectionYear(
            Year: year,
            Grades: GradeOrder.ToDictionary(
                grade => grade,
                grade => grades.GetValueOrDefault(grade),
                StringComparer.OrdinalIgnoreCase),
            NewStudentsByGrade: [],
            NeighborhoodStudents: new Dictionary<string, double>(gridTotals, StringComparer.OrdinalIgnoreCase),
            GridTotals: new Dictionary<string, double>(gridTotals, StringComparer.OrdinalIgnoreCase),
            GridGrades: [],
            SchoolTotals: [],
            SchoolGrades: [],
            TotalStudents: total,
            NewStudentsTotal: 0);
    }

    private static double GradeValue(ProjectionYear year, string grade)
    {
        return year.Grades.GetValueOrDefault(grade);
    }

    private static double GridValue(ProjectionYear year, string grid)
    {
        return year.GridTotals.GetValueOrDefault(grid);
    }

    private static IReadOnlyList<CohortDefinition> BuildProgressingCohorts(IReadOnlyList<ProjectionYear> projection)
    {
        if (projection.Count == 0) return [];
        var firstProjectionYear = projection.Min(point => point.Year);
        var lastProjectionYear = projection.Max(point => point.Year);
        var firstCohortStart = firstProjectionYear - 13;
        var lastCohortStart = lastProjectionYear;

        return Enumerable.Range(firstCohortStart, lastCohortStart - firstCohortStart + 1)
            .Select(startYear => new CohortDefinition(
                StartYear: startYear,
                EndYear: startYear + 13,
                Label: $"{startYear % 100:00}-{(startYear + 13) % 100:00}"))
            .ToList();
    }

    private static IReadOnlyList<double> ParseCandidates(string text)
    {
        return text.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(item => double.TryParse(item, out var value) ? Math.Clamp(value, 0, 1) : double.NaN)
            .Where(value => !double.IsNaN(value))
            .Distinct()
            .ToList();
    }

    private MonteCarloYearComparison? SelectedComparison => Result?.Comparisons.FirstOrDefault(item => item.Year == SelectedComparisonYear);

    private IReadOnlyList<(string Grid, double? Actual, double Modeled)> SelectedGridComparisons =>
        SelectedComparison is null
            ? []
            : SelectedComparison.ModeledGridTotals.Keys.Order()
                .Where(grid => !ExcludedValidationGrids.Contains(grid))
                .Select(grid => (grid, SelectedComparison.ActualGridTotals.GetValueOrDefault(grid), SelectedComparison.ModeledGridTotals.GetValueOrDefault(grid)))
                .ToList();

    private IReadOnlyList<(string Grade, double? Actual, double AdjustedActual, double Modeled)> SelectedGradeComparisons =>
        SelectedComparison is null
            ? []
            : VisibleGradeOrder
                .Select(grade => (
                    grade,
                    SelectedComparison.ActualGrades.GetValueOrDefault(grade),
                    SelectedComparison.AdjustedActualGrades.GetValueOrDefault(grade),
                    SelectedComparison.ModeledGrades.GetValueOrDefault(grade)))
                .ToList();

    private double ChartMax => ChartAxis.NiceMaximum(Math.Max(1, Result?.Comparisons.SelectMany(item => new[] { item.ActualGridTotal, item.ModeledGridTotal }).DefaultIfEmpty(0).Max() * 1.08 ?? 1));
    private string ActualChartPoints => ChartPoints(item => HasReferenceData(item) ? item.ActualGridTotal : null);
    private string ModeledChartPoints => ChartPoints(item => item.ModeledGridTotal);

    private IReadOnlyList<string> ComparisonChartEntities => ComparisonChartMode switch
    {
        "grid" => Result?.Comparisons.FirstOrDefault()?.ModeledGridTotals.Keys
            .Where(grid => !ExcludedValidationGrids.Contains(grid))
            .Order()
            .ToList() ?? [],
        "grade" => VisibleGradeOrder,
        _ => ["Validation total"]
    };

    private string EffectiveComparisonChartEntity =>
        ComparisonChartEntities.Contains(ComparisonChartEntity)
            ? ComparisonChartEntity
            : ComparisonChartEntities.FirstOrDefault() ?? "Validation total";

    private IReadOnlyList<double?> ComparisonActualValues => Result?.Comparisons
        .Select(comparison => ComparisonChartMode switch
        {
            "grid" => comparison.ActualGridTotals.GetValueOrDefault(EffectiveComparisonChartEntity),
            "grade" => HasReferenceData(comparison) ? comparison.AdjustedActualGrades.GetValueOrDefault(EffectiveComparisonChartEntity) : null,
            _ => HasReferenceData(comparison) ? comparison.ActualGridTotal : null
        })
        .ToList() ?? [];

    private IReadOnlyList<double?> ComparisonModeledValues => Result?.Comparisons
        .Select(comparison => ComparisonChartMode switch
        {
            "grid" => (double?)comparison.ModeledGridTotals.GetValueOrDefault(EffectiveComparisonChartEntity),
            "grade" => (double?)comparison.ModeledGrades.GetValueOrDefault(EffectiveComparisonChartEntity),
            _ => (double?)comparison.ModeledGridTotal
        })
        .ToList() ?? [];

    private double ComparisonChartMax => ChartAxis.NiceMaximum(Math.Max(1, ComparisonActualValues.Concat(ComparisonModeledValues).Where(value => value.HasValue).Select(value => value!.Value).DefaultIfEmpty(0).Max() * 1.08));
    private string ComparisonActualChartPoints => ComparisonChartPoints(ComparisonActualValues);
    private string ComparisonModeledChartPoints => ComparisonChartPoints(ComparisonModeledValues);

    private static bool HasReferenceData(MonteCarloYearComparison comparison)
    {
        return comparison.ActualGridTotal > 0 || comparison.ActualGradeTotal > 0;
    }

    private string ChartPoints(Func<MonteCarloYearComparison, double?> selector)
    {
        var points = Result?.Comparisons ?? [];
        if (points.Count == 0) return "";
        return string.Join(" ", points.Select((point, index) =>
        {
            var value = selector(point);
            if (!value.HasValue) return null;
            var x = points.Count == 1 ? 60 : 60 + (index * 800.0 / (points.Count - 1));
            var y = 260 - (value.Value / ChartMax * 220);
            return $"{x:0.##},{y:0.##}";
        }).Where(point => point is not null));
    }

    private double TotalXForIndex(int index)
    {
        var points = Result?.Comparisons ?? [];
        return points.Count == 1 ? 60 : 60 + (index * 800.0 / (points.Count - 1));
    }

    private double TotalYForValue(double value)
    {
        return 260 - (value / ChartMax * 220);
    }

    private double TotalHoverX => TotalChartHoverIndex.HasValue ? TotalXForIndex(TotalChartHoverIndex.Value) : 60;

    private double TotalHoverYearLabelX => Math.Clamp(TotalHoverX - 29, 62, 802);

    private double TotalHoverPanelX => TotalHoverX > 650 ? 650 - 180 : 650;

    private double TotalHoverPanelY => 72;

    private IReadOnlyList<(int Index, double X, double Width)> TotalHoverZones
    {
        get
        {
            var points = Result?.Comparisons ?? [];
            if (points.Count == 0) return [];
            if (points.Count == 1) return [(0, 60, 800)];

            var zones = new List<(int Index, double X, double Width)>();
            for (var index = 0; index < points.Count; index++)
            {
                var previousMid = index == 0 ? 60 : (TotalXForIndex(index - 1) + TotalXForIndex(index)) / 2;
                var nextMid = index == points.Count - 1 ? 860 : (TotalXForIndex(index) + TotalXForIndex(index + 1)) / 2;
                zones.Add((index, previousMid, nextMid - previousMid));
            }

            return zones;
        }
    }

    private IReadOnlyList<(double X, double Y, string Label, string Color)> TotalHoverMarkers
    {
        get
        {
            var points = Result?.Comparisons ?? [];
            if (!TotalChartHoverIndex.HasValue || TotalChartHoverIndex.Value < 0 || TotalChartHoverIndex.Value >= points.Count) return [];

            var index = TotalChartHoverIndex.Value;
            var point = points[index];
            var x = TotalXForIndex(index);
            var markers = new List<(double X, double Y, string Label, string Color)>
            {
                (x, TotalYForValue(point.ModeledGridTotal), $"Modeled: {point.ModeledGridTotal:N0}", "#b45309")
            };

            if (HasReferenceData(point))
            {
                markers.Insert(0, (x, TotalYForValue(point.ActualGridTotal), $"Actual: {point.ActualGridTotal:N0}", "#0f766e"));
            }

            return markers;
        }
    }

    private string ComparisonChartPoints(IReadOnlyList<double?> values)
    {
        if (values.Count == 0) return "";
        var max = ComparisonChartMax;
        return string.Join(" ", values.Select((value, index) =>
        {
            if (!value.HasValue) return null;
            var x = values.Count == 1 ? 60 : 60 + (index * 800.0 / (values.Count - 1));
            var y = 260 - (value.Value / max * 220);
            return $"{x:0.##},{y:0.##}";
        }).Where(point => point is not null));
    }

    private IReadOnlyList<(double Y, string Label)> YTicks => ChartAxis.YTicks(ChartMax, 40, 260);

    private IReadOnlyList<(double X, string Label)> XTicks
    {
        get
        {
            var points = Result?.Comparisons ?? [];
            if (points.Count == 0) return [];
            var step = Math.Max(1, (int)Math.Ceiling(points.Count / 8.0));
            return points.Select((point, index) => new { point.Year, index })
                .Where(item => item.index % step == 0 || item.index == points.Count - 1)
                .Select(item =>
                {
                    var x = points.Count == 1 ? 60 : 60 + (item.index * 800.0 / (points.Count - 1));
                    return (x, item.Year.ToString());
                })
                .ToList();
        }
    }

    private IReadOnlyList<(double Y, string Label)> ComparisonYTicks => ChartAxis.YTicks(ComparisonChartMax, 40, 260);

    private IReadOnlyList<(double X, string Label)> ComparisonXTicks
    {
        get
        {
            var points = Result?.Comparisons ?? [];
            if (points.Count == 0) return [];
            var step = Math.Max(1, (int)Math.Ceiling(points.Count / 8.0));
            return points.Select((point, index) => new { point.Year, index })
                .Where(item => item.index % step == 0 || item.index == points.Count - 1)
                .Select(item =>
                {
                    var x = points.Count == 1 ? 60 : 60 + (item.index * 800.0 / (points.Count - 1));
                    return (x, item.Year.ToString());
                })
                .ToList();
        }
    }

    private static string FormatNullable(double? value) => value.HasValue ? value.Value.ToString("N0") : "n/a";
}
