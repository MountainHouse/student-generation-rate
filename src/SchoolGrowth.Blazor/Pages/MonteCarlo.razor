    protected override async Task OnInitializedAsync()
    {
        try
        {
            var homes = await Http.GetStringAsync("data/homes.csv");
            var grid = await Http.GetStringAsync("data/grid.csv");
            var grade = await Http.GetStringAsync("data/grade.csv");
            var schools = await Http.GetStringAsync("data/schools.csv");
            Data = EnrollmentData.LoadFromCsvText(homes, grid, grade, schools);
            Model = new MonteCarloEnrollmentModel(Data);
            StartYear = Math.Max(MinStartYear, LatestReferenceYear - 5);
            EndYear = LatestReferenceYear;
            SelectedComparisonYear = EndYear;
            await DetectServerApiAsync();
            _ = RunValidationAsync();
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }
    }

    private async Task RunValidationAsync()
    {
        if (Model is null) return;
        ValidationDebounce?.Cancel();
        ValidationDebounce?.Dispose();
        var debounce = new CancellationTokenSource();
        ValidationDebounce = debounce;

        try
        {
            await Task.Delay(600, debounce.Token);
            if (!debounce.IsCancellationRequested)
            {
                await ExecuteValidationAsync();
            }
        }
        catch (TaskCanceledException)
        {
            // A newer edit superseded this validation request.
        }
    }

    private async Task ExecuteValidationAsync()
    {
        if (Model is null) return;
        if (ValidationRunning)
        {
            PendingValidation = true;
            return;
        }

        ValidationRunning = true;
        do
        {
            PendingValidation = false;
            var executionLabel = ShouldUseServer() ? "server" : "browser";
            StatusMessage = $"Running Monte Carlo validation on {executionLabel}: {Runs:N0} runs...";
            await InvokeAsync(StateHasChanged);
            await Task.Yield();

            try
            {
                var ran = await RunValidationCoreAsync();
                StatusMessage = ran
                    ? $"Validation complete on {LastExecutionLabel}: {Runs:N0} runs, score {Result?.CombinedScore:P2}. {ServerApiStatus}"
                    : ServerApiStatus;
            }
            catch (Exception ex)
            {
                StatusMessage = $"Validation failed: {ex.Message}";
            }
            await InvokeAsync(StateHasChanged);
        }
        while (PendingValidation);

        ValidationRunning = false;
    }

    private async Task<bool> RunValidationCoreAsync()
    {
        if (Model is null) return false;
        StartYear = Math.Clamp(StartYear, MinStartYear, MaxSimulationEndYear);
        EndYear = Math.Clamp(EndYear, StartYear, MaxSimulationEndYear);
        Runs = Math.Clamp(Runs, 1, 10000);

        var request = new MonteCarloValidationRequest(
            StartYear,
            EndYear,
            CurrentParameters());

        if (ShouldUseServer())
        {
            try
            {
                Result = await PostServerAsync<MonteCarloValidationRequest, MonteCarloValidationResult>("api/monte-carlo/validate", request);
                ServerApiAvailable = true;
                ServerApiStatus = $"Server API: {ServerApiBaseAddress}";
                LastExecutionLabel = "server";
            }
            catch (Exception ex) when (ExecutionMode != "Server")
            {
                ServerApiAvailable = false;
                LastExecutionLabel = "none";
                ServerApiStatus = $"Server unavailable; validation was not run in the browser automatically ({ex.Message}). Select Browser only with {BrowserRunLimit:N0} runs or fewer, or restart the server API.";
                return false;
            }
        }
        else
        {
            if (Runs > BrowserRunLimit)
            {
                LastExecutionLabel = "none";
                ServerApiStatus = $"Browser validation skipped: reduce runs to {BrowserRunLimit:N0} or fewer, or use the Server API.";
                return false;
            }

            Result = Model.Validate(request);
            LastExecutionLabel = "browser";
            ServerApiStatus = BrowserOnlyStatus();
        }

        if (Result is null)
        {
            return false;
        }

        if (!Result.Comparisons.Any(item => item.Year == SelectedComparisonYear))
        {
            SelectedComparisonYear = Result.Comparisons.LastOrDefault()?.Year ?? EndYear;
        }

        if (!ComparisonChartEntities.Contains(ComparisonChartEntity))
        {
            ComparisonChartEntity = ComparisonChartEntities.FirstOrDefault() ?? "Validation total";
        }

        return true;
    }

    private async Task FindBest()
    {
        if (Model is null) return;
        SearchRunning = true;
        StatusMessage = "Searching Monte Carlo parameter candidates...";
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            var request = new MonteCarloSearchRequest(
                StartYear,
                EndYear,
                Math.Clamp(SearchRuns, 1, 2000),
                Seed,
                ParseCandidates(OwnershipCandidatesText),
                ParseCandidates(ZeroChildCandidatesText),
                ParseCandidates(OneChildCandidatesText),
                ParseCandidates(TwoChildCandidatesText),
                ParseCandidates(ThreeChildCandidatesText),
                ParseCandidates(FourPlusChildCandidatesText),
                ParseCandidates(ExitCandidatesText));

            if (ShouldUseServer())
            {
                try
                {
                    SearchResult = await PostServerAsync<MonteCarloSearchRequest, MonteCarloSearchResult>("api/monte-carlo/search", request);
                    LastExecutionLabel = "server";
                }
                catch (Exception ex) when (ExecutionMode != "Server")
                {
                    ServerApiAvailable = false;
                    ServerApiStatus = $"Server unavailable; parameter search was not run in the browser automatically ({ex.Message}). Select Browser only with {BrowserRunLimit:N0} runs per candidate or fewer, or restart the server API.";
                    LastExecutionLabel = "none";
                    return;
                }
            }
            else
            {
                if (request.RunsPerCandidate > BrowserRunLimit)
                {
                    LastExecutionLabel = "none";
                    StatusMessage = $"Browser search skipped: reduce runs per candidate to {BrowserRunLimit:N0} or fewer, or use the Server API.";
                    return;
                }

                SearchResult = Model.FindBest(request);
                LastExecutionLabel = "browser";
            }

            if (SearchResult is not null)
            {
                StatusMessage = $"Search complete on {LastExecutionLabel}: {SearchResult.Candidates.Count:N0} candidates, best score {SearchResult.Best.CombinedScore:P2}.";
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            SearchRunning = false;
        }
    }

    private void UseBest()
    {
        if (SearchResult is null) return;
        ApplyParameters(SearchResult.Best.Parameters);
        _ = RunValidationAsync();
    }

    private async Task DetectServerApiAsync()
    {
        var candidates = new[]
        {
            Http.BaseAddress?.ToString().TrimEnd('/'),
            "http://localhost:5003",
            "https://localhost:7275"
        }
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();

        foreach (var candidate in candidates)
        {
            try
            {
                using var client = new HttpClient { BaseAddress = new Uri(candidate! + "/") };
                using var response = await client.GetAsync("api/monte-carlo/status");
                if (!response.IsSuccessStatusCode)
                {
                    continue;
                }

                ServerApiBaseAddress = candidate!;
                ServerApiAvailable = true;
                ServerApiStatus = $"Server API detected: {ServerApiBaseAddress}";
                return;
            }
            catch
            {
                // Browser-only mode remains available when the server host is absent.
            }
        }

        ServerApiAvailable = false;
        ServerApiBaseAddress = candidates.FirstOrDefault() ?? "";
        ServerApiStatus = "Server API not detected; browser-only mode is active.";
    }

    private bool ShouldUseServer()
    {
        return ExecutionMode switch
        {
            "Server" => true,
            "Browser" => false,
            _ => ServerApiAvailable && !string.IsNullOrWhiteSpace(ServerApiBaseAddress)
        };
    }

    private string BrowserOnlyStatus()
    {
        return ExecutionMode == "Browser"
            ? "Browser-only mode selected."
            : ServerApiStatus ?? "Browser-only mode is active.";
    }

    private async Task<TResponse> PostServerAsync<TRequest, TResponse>(string relativeUrl, TRequest request)
    {
        if (string.IsNullOrWhiteSpace(ServerApiBaseAddress))
        {
            throw new InvalidOperationException("Server API address is empty.");
        }

        using var client = new HttpClient { BaseAddress = new Uri(ServerApiBaseAddress.TrimEnd('/') + "/") };
        using var response = await client.PostAsJsonAsync(relativeUrl, request);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<TResponse>()
            ?? throw new InvalidOperationException("Server API returned an empty response.");
    }

