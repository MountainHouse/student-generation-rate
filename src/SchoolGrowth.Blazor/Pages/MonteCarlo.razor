    private bool IsToolActive(string id) => ActiveToolIds.Contains(id);

    private bool IsToolCollapsed(string id) => CollapsedToolIds.Contains(id);

    private string ToolStyle(string id) => $"order: {Math.Max(0, ActiveToolIds.IndexOf(id))};";

    private bool CanMoveToolUp(string id) => ActiveToolIds.IndexOf(id) > 0;

    private bool CanMoveToolDown(string id)
    {
        var index = ActiveToolIds.IndexOf(id);
        return index >= 0 && index < ActiveToolIds.Count - 1;
    }

    private void ToggleTool(string id)
    {
        if (!CollapsedToolIds.Add(id))
        {
            CollapsedToolIds.Remove(id);
        }
    }

    private void MoveToolUp(string id)
    {
        var index = ActiveToolIds.IndexOf(id);
        if (index <= 0) return;

        (ActiveToolIds[index - 1], ActiveToolIds[index]) = (ActiveToolIds[index], ActiveToolIds[index - 1]);
    }

    private void MoveToolDown(string id)
    {
        var index = ActiveToolIds.IndexOf(id);
        if (index < 0 || index >= ActiveToolIds.Count - 1) return;

        (ActiveToolIds[index + 1], ActiveToolIds[index]) = (ActiveToolIds[index], ActiveToolIds[index + 1]);
    }

    private void RemoveTool(string id)
    {
        ActiveToolIds.Remove(id);
        CollapsedToolIds.Remove(id);
        if (string.IsNullOrWhiteSpace(NewToolId))
        {
            NewToolId = id;
        }
    }

    private void AddSelectedTool()
    {
        var id = !string.IsNullOrWhiteSpace(NewToolId) && InactiveTools.Any(tool => tool.Id == NewToolId)
            ? NewToolId
            : InactiveTools.FirstOrDefault()?.Id;
        if (string.IsNullOrWhiteSpace(id) || ActiveToolIds.Contains(id)) return;

        ActiveToolIds.Add(id);
        CollapsedToolIds.Remove(id);
        NewToolId = "";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var homes = await Http.GetStringAsync("data/homes.csv");
            var grid = await Http.GetStringAsync("data/grid.csv");
            var grade = await Http.GetStringAsync("data/grade.csv");
            var schools = await Http.GetStringAsync("data/schools.csv");
            Data = EnrollmentData.LoadFromCsvText(homes, grid, grade, schools);
            Model = new MonteCarloEnrollmentModel(Data);
            await LoadPresetsAsync();
            StartYear = Math.Max(MinStartYear, LatestReferenceYear - 5);
            EndYear = LatestReferenceYear;
            SelectedComparisonYear = EndYear;
            await DetectServerApiAsync();
            _ = RunValidationAsync();
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
        }
    }

