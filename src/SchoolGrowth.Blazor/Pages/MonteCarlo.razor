@page "/monte-carlo"
@inject HttpClient Http
@inject IJSRuntime Js

<PageTitle>Monte Carlo Model</PageTitle>

<header class="topbar">
    <div>
        <h1>Monte Carlo Model</h1>
        <p>Validate a household-style simulation against grid and grade reference data.</p>
    </div>
    <div class="top-actions">
        <a class="nav-button secondary" href="">Simulator</a>
        <a class="nav-button secondary" href="validation">Model Validation</a>
    </div>
</header>

@if (LoadError is not null)
{
    <section class="band">
        <strong>@LoadError</strong>
    </section>
}
else if (Data is null)
{
    <section class="band">Loading Monte Carlo model...</section>
}
else
{
    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <section class="band status-band">
            <strong>@StatusMessage</strong>
        </section>
    }

    <section class="band tool-menu">
        <div class="section-head">
            <h2>Tools</h2>
            <div class="tool-create">
                <select @bind="NewToolId" disabled="@(!InactiveTools.Any())">
                    <option value="">@(InactiveTools.Any() ? "Select tool" : "All tools visible")</option>
                    @foreach (var tool in InactiveTools)
                    {
                        <option value="@tool.Id">@tool.Title</option>
                    }
                </select>
                <button type="button" class="secondary" disabled="@(!InactiveTools.Any())" @onclick="AddSelectedTool">Add Tool</button>
            </div>
        </div>
        <div class="tool-strip">
            @foreach (var tool in ActiveTools)
            {
                <button type="button" class="secondary tool-chip" @onclick="() => ToggleTool(tool.Id)">
                    @(IsToolCollapsed(tool.Id) ? "+" : "-") @tool.Title
                </button>
            }
        </div>
    </section>

    <div class="tool-board">
    @if (IsToolActive(ToolRunEnvironment))
    {
    <ToolPanel Id="@ToolRunEnvironment" Title="Run Environment" Style="@ToolStyle(ToolRunEnvironment)"
               Collapsed="@IsToolCollapsed(ToolRunEnvironment)" CanMoveUp="@CanMoveToolUp(ToolRunEnvironment)" CanMoveDown="@CanMoveToolDown(ToolRunEnvironment)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
        <div class="controls monte-controls">
            <label>
                <span>Parameter preset</span>
                <select value="@SelectedPresetName" @onchange="LoadPresetAsync">
                    @foreach (var preset in ParameterPresets)
                    {
                        <option value="@preset.Name">@preset.Name</option>
                    }
                </select>
            </label>
            @if (SelectedPreset is not null)
            {
                <div class="preset-note">@SelectedPreset.Description</div>
            }
            <label>
                <span>Runs</span>
                <input type="number" min="10" max="10000" step="10" @bind="Runs" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>Seed</span>
                <input type="number" @bind="Seed" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>Execution</span>
                <select @bind="ExecutionMode" @bind:after="RunValidationAsync">
                    <option value="Auto">Auto server preferred</option>
                    <option value="Server">Server API</option>
                    <option value="Browser">Browser only</option>
                </select>
            </label>
            <label>
                <span>Server API</span>
                <input @bind="ServerApiBaseAddress" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>Max parallelism</span>
                <input type="number" min="0" step="1" @bind="MaxDegreeOfParallelism" @bind:after="RunValidationAsync" />
            </label>
        </div>
    </ToolPanel>
    }

    @if (IsToolActive(ToolModelSettings))
    {
    <ToolPanel Id="@ToolModelSettings" Title="Model Settings" Style="@ToolStyle(ToolModelSettings)"
               Collapsed="@IsToolCollapsed(ToolModelSettings)" CanMoveUp="@CanMoveToolUp(ToolModelSettings)" CanMoveDown="@CanMoveToolDown(ToolModelSettings)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
        <div class="settings-stack">
        <details class="settings-subpanel" open>
        <summary>Planning Window</summary>
        <div class="controls monte-controls">
            <label>
                <span>Start year</span>
                <input type="number" min="@MinStartYear" max="@MaxSimulationEndYear" @bind="StartYear" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>End year</span>
                <input type="number" min="@StartYear" max="@MaxSimulationEndYear" @bind="EndYear" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>Ownership change</span>
                <input type="number" min="0" max="1" step="0.005" @bind="OwnershipChangeProbability" @bind:after="RunValidationAsync" />
            </label>
        </div>
        </details>
        <details class="settings-subpanel" open>
        <summary>Move-In Kids Count</summary>
        <div class="normalized-inputs">
            <label>
                <span>0 child share</span>
                <span class="normalized-input"><input type="number" min="0" max="1" step="0.005" value="@MoveInZeroChildShare" @oninput="value => MoveInZeroChildShare = ParseInputDouble(value, MoveInZeroChildShare)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInChildCountNormalizers[0])</output></span>
            </label>
            <label>
                <span>1 child share</span>
                <span class="normalized-input"><input type="number" min="0" max="1" step="0.005" value="@MoveInOneChildShare" @oninput="value => MoveInOneChildShare = ParseInputDouble(value, MoveInOneChildShare)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInChildCountNormalizers[1])</output></span>
            </label>
            <label>
                <span>2 child share</span>
                <span class="normalized-input"><input type="number" min="0" max="1" step="0.005" value="@MoveInTwoChildShare" @oninput="value => MoveInTwoChildShare = ParseInputDouble(value, MoveInTwoChildShare)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInChildCountNormalizers[2])</output></span>
            </label>
            <label>
                <span>3 child share</span>
                <span class="normalized-input"><input type="number" min="0" max="1" step="0.005" value="@MoveInThreeChildShare" @oninput="value => MoveInThreeChildShare = ParseInputDouble(value, MoveInThreeChildShare)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInChildCountNormalizers[3])</output></span>
            </label>
            <label>
                <span>4 child share</span>
                <span class="normalized-input"><input type="number" min="0" max="1" step="0.005" value="@MoveInFourPlusChildShare" @oninput="value => MoveInFourPlusChildShare = ParseInputDouble(value, MoveInFourPlusChildShare)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInChildCountNormalizers[4])</output></span>
            </label>
        </div>
        </details>
        <details class="settings-subpanel" open>
        <summary>Move-In Kids Age</summary>
        <div class="normalized-inputs">
            <label>
                <span>Preschool weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.01" value="@MoveInPreschoolWeight" @oninput="value => MoveInPreschoolWeight = ParseInputDouble(value, MoveInPreschoolWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInAgeNormalizers[0])</output></span>
            </label>
            <label>
                <span>TK/K weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.01" value="@MoveInTkKWeight" @oninput="value => MoveInTkKWeight = ParseInputDouble(value, MoveInTkKWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInAgeNormalizers[1])</output></span>
            </label>
            <label>
                <span>Elementary weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.01" value="@MoveInElementaryWeight" @oninput="value => MoveInElementaryWeight = ParseInputDouble(value, MoveInElementaryWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInAgeNormalizers[2])</output></span>
            </label>
            <label>
                <span>Middle weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.01" value="@MoveInMiddleWeight" @oninput="value => MoveInMiddleWeight = ParseInputDouble(value, MoveInMiddleWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInAgeNormalizers[3])</output></span>
            </label>
            <label>
                <span>High weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.01" value="@MoveInHighWeight" @oninput="value => MoveInHighWeight = ParseInputDouble(value, MoveInHighWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInAgeNormalizers[4])</output></span>
            </label>
            <label>
                <span>Post-school weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.01" value="@MoveInPostSchoolWeight" @oninput="value => MoveInPostSchoolWeight = ParseInputDouble(value, MoveInPostSchoolWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(MoveInAgeNormalizers[5])</output></span>
            </label>
        </div>
        </details>
        <details class="settings-subpanel" open>
        <summary>Birth/New Child Rates</summary>
        <div class="controls monte-controls">
        <label>
            <span>1st birth / year</span>
            <input type="number" min="0" max="1" step="0.001" @bind="AnnualFirstNewChildProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>2nd birth / year</span>
            <input type="number" min="0" max="1" step="0.001" @bind="AnnualSecondNewChildProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>3rd birth / year</span>
            <input type="number" min="0" max="1" step="0.001" @bind="AnnualThirdNewChildProbability" @bind:after="RunValidationAsync" />
        </label>
        <label>
            <span>4th+ birth / year</span>
            <input type="number" min="0" max="1" step="0.001" @bind="AnnualFourthPlusNewChildProbability" @bind:after="RunValidationAsync" />
        </label>
        </div>
        </details>
        <details class="settings-subpanel settings-subpanel-wide" open>
        <summary>Density Factors</summary>
        <div class="controls monte-controls">
        <label>
            <span>Low/medium factor</span>
            <input type="number" min="0" step="0.01" value="@DensityLowMediumFactor" @oninput="value => DensityLowMediumFactor = ParseInputDouble(value, DensityLowMediumFactor)" @onchange="RunValidationAsync" />
        </label>
        <label>
            <span>Medium-high factor</span>
            <input type="number" min="0" step="0.01" value="@DensityMediumHighFactor" @oninput="value => DensityMediumHighFactor = ParseInputDouble(value, DensityMediumHighFactor)" @onchange="RunValidationAsync" />
        </label>
        <label>
            <span>High factor</span>
            <input type="number" min="0" step="0.01" value="@DensityHighFactor" @oninput="value => DensityHighFactor = ParseInputDouble(value, DensityHighFactor)" @onchange="RunValidationAsync" />
        </label>
        </div>
        <div class="density-factor-table">
            <table>
                <thead>
                    <tr>
                        <th>Density</th>
                        <th>0 child</th>
                        <th>1st child</th>
                        <th>2nd child</th>
                        <th>3rd child</th>
                        <th>4th child</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in DensityEffectRows)
                    {
                        <tr>
                            <td>@row.Label</td>
                            @foreach (var child in row.Children)
                            {
                                <td>
                                    @if (child.ChildNumber == 0)
                                    {
                                    }
                                    else if (child.ChildNumber == 1)
                                    {
                                        <input type="number" min="0" step="0.01" value="@row.FirstFactor.Value" @oninput="value => row.FirstFactor.Value = ParseInputDouble(value, row.FirstFactor.Value)" @onchange="RunValidationAsync" />
                                    }
                                    else if (child.ChildNumber == 2)
                                    {
                                        <input type="number" min="0" step="0.01" value="@row.SecondFactor.Value" @oninput="value => row.SecondFactor.Value = ParseInputDouble(value, row.SecondFactor.Value)" @onchange="RunValidationAsync" />
                                    }
                                    else if (child.ChildNumber == 3)
                                    {
                                        <input type="number" min="0" step="0.01" value="@row.ThirdFactor.Value" @oninput="value => row.ThirdFactor.Value = ParseInputDouble(value, row.ThirdFactor.Value)" @onchange="RunValidationAsync" />
                                    }
                                    else
                                    {
                                    }
                                    <div class="density-effective">
                                        <span>Move-in @FormatNormalized(child.MoveInShare)</span>
                                        <span>Birth @FormatPoint(child.BirthProbability)</span>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        </details>
        <details class="settings-subpanel" open>
        <summary>Exit Probabilities</summary>
        <div class="controls monte-controls">
            <label>
                <span>TK-8 exit</span>
                <input type="number" min="0" max="1" step="0.005" @bind="Tk8ExitProbability" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>High school exit</span>
                <input type="number" min="0" max="1" step="0.005" @bind="HighSchoolExitProbability" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>Special ed exit</span>
                <input type="number" min="0" max="1" step="0.005" @bind="SpecialExitProbability" @bind:after="RunValidationAsync" />
            </label>
        </div>
        </details>
        <details class="settings-subpanel" open>
        <summary>Other Settings</summary>
        <div class="controls monte-controls">
            <label>
                <span>Special ed probability</span>
                <input type="number" min="0" max="1" step="0.001" @bind="SpecialEducationProbability" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>Same school year</span>
                <input type="number" min="0" max="1" step="0.005" @bind="SameSchoolYearProbability" @bind:after="RunValidationAsync" />
            </label>
        </div>
        </details>
        </div>
    </ToolPanel>
    }

    @if (IsToolActive(ToolModelScoring))
    {
    <ToolPanel Id="@ToolModelScoring" Title="Model Scoring" Style="@ToolStyle(ToolModelScoring)"
               Collapsed="@IsToolCollapsed(ToolModelScoring)" CanMoveUp="@CanMoveToolUp(ToolModelScoring)" CanMoveDown="@CanMoveToolDown(ToolModelScoring)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
        <div class="controls monte-controls">
            <label>
                <span>Total score weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.1" value="@ScoreTotalWeight" @oninput="value => ScoreTotalWeight = ParseInputDouble(value, ScoreTotalWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(ScoreWeightNormalizers[0])</output></span>
            </label>
            <label>
                <span>Grid score weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.1" value="@ScoreGridWeight" @oninput="value => ScoreGridWeight = ParseInputDouble(value, ScoreGridWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(ScoreWeightNormalizers[1])</output></span>
            </label>
            <label>
                <span>Grade score weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.1" value="@ScoreGradeWeight" @oninput="value => ScoreGradeWeight = ParseInputDouble(value, ScoreGradeWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(ScoreWeightNormalizers[2])</output></span>
            </label>
            <label>
                <span>Grade smoothing window</span>
                <input type="number" min="0" max="4" step="1" @bind="GradeSmoothingWindow" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>HS total score weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.1" value="@ScoreHighSchoolTotalWeight" @oninput="value => ScoreHighSchoolTotalWeight = ParseInputDouble(value, ScoreHighSchoolTotalWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(ScoreWeightNormalizers[3])</output></span>
            </label>
            <label>
                <span>HS grade score weight</span>
                <span class="normalized-input"><input type="number" min="0" step="0.1" value="@ScoreHighSchoolGradeWeight" @oninput="value => ScoreHighSchoolGradeWeight = ParseInputDouble(value, ScoreHighSchoolGradeWeight)" @onchange="RunValidationAsync" /><output>@FormatNormalized(ScoreWeightNormalizers[4])</output></span>
            </label>
            <label>
                <span>Year weight slope</span>
                <input type="number" min="0" step="0.05" @bind="YearWeightSlope" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>Year weight cap</span>
                <input type="number" min="0.01" step="0.1" @bind="YearWeightCap" @bind:after="RunValidationAsync" />
            </label>
            <label>
                <span>Anchor year weight</span>
                <input type="number" min="0" step="0.05" @bind="AnchorYearWeight" @bind:after="RunValidationAsync" />
            </label>
        </div>
    </ToolPanel>
    }

    @if (Result is null && ActiveTools.Any(tool => ResultToolIds.Contains(tool.Id)))
    {
        <section class="band">Choose parameters or wait for the first validation run.</section>
    }
    else
    {
    @if (IsToolActive(ToolValidationSummary))
    {
    <ToolPanel Id="@ToolValidationSummary" Title="Validation Summary" CssClass="band tool-panel charts-tool" Style="@ToolStyle(ToolValidationSummary)"
               Collapsed="@IsToolCollapsed(ToolValidationSummary)" CanMoveUp="@CanMoveToolUp(ToolValidationSummary)" CanMoveDown="@CanMoveToolDown(ToolValidationSummary)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
    <div class="charts">
        <div class="chart-box">
            <h2>Actual vs Monte Carlo Grid Total</h2>
            <svg viewBox="0 0 920 300" role="img" @onmouseleave="() => TotalChartHoverIndex = null">
                @foreach (var tick in YTicks)
                {
                    <line x1="60" y1="@tick.Y" x2="860" y2="@tick.Y" class="chart-grid" />
                    <SvgText X="50" Y="@(tick.Y + 4)" Anchor="end" Label="@tick.Label" />
                }
                <line x1="60" y1="260" x2="860" y2="260" class="chart-axis" />
                <line x1="60" y1="40" x2="60" y2="260" class="chart-axis" />
                @foreach (var tick in XTicks)
                {
                    <line x1="@tick.X" y1="260" x2="@tick.X" y2="266" class="chart-axis" />
                    <SvgText X="@tick.X" Y="284" Anchor="middle" Label="@tick.Label" />
                }
                <polyline points="@ActualChartPoints" fill="none" stroke="#0f766e" stroke-width="4" />
                <polyline points="@ModeledChartPoints" fill="none" stroke="#b45309" stroke-width="4" />
                @if (TotalChartHoverIndex.HasValue)
                {
                    <line x1="@TotalHoverX" y1="40" x2="@TotalHoverX" y2="260" class="chart-hover-line" />
                    <rect x="@TotalHoverYearLabelX" y="44" width="58" height="20" rx="4" class="chart-hover-label-bg" />
                    <SvgText X="@(TotalHoverYearLabelX + 29)" Y="58" Anchor="middle" Label="@Result!.Comparisons[TotalChartHoverIndex.Value].Year.ToString()" />
                    @foreach (var marker in TotalHoverMarkers)
                    {
                        <circle cx="@marker.X" cy="@marker.Y" r="4" fill="@marker.Color" class="chart-hover-dot" />
                    }
                    <rect x="@TotalHoverPanelX" y="@TotalHoverPanelY" width="180" height="48" rx="5" class="chart-hover-label-bg" />
                    @foreach (var item in TotalHoverMarkers.Select((marker, index) => new { marker, index }))
                    {
                        <circle cx="@(TotalHoverPanelX + 10)" cy="@(TotalHoverPanelY + 17 + item.index * 17)" r="3" fill="@item.marker.Color" class="chart-hover-dot" />
                        <SvgText X="@(TotalHoverPanelX + 18)" Y="@(TotalHoverPanelY + 21 + item.index * 17)" Anchor="start" Label="@item.marker.Label" />
                    }
                }
                @foreach (var zone in TotalHoverZones)
                {
                    <rect x="@zone.X" y="40" width="@zone.Width" height="220" fill="transparent" class="chart-hover-zone"
                          @onmouseover="() => TotalChartHoverIndex = zone.Index"
                          @onfocus="() => TotalChartHoverIndex = zone.Index" />
                }
            </svg>
            <div class="inline-legend">
                <span><i style="background:#0f766e"></i>Actual</span>
                <span><i style="background:#b45309"></i>Monte Carlo mean</span>
            </div>
        </div>
        <div class="chart-box">
            <h2>Validation Error</h2>
            <dl>
                <dt>Total MAE</dt>
                <dd>@Result!.GridMeanAbsoluteError.ToString("N0")</dd>
                <dt>Total MAPE</dt>
                <dd>@Result.GridMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>Grid/year MAE</dt>
                <dd>@Result.GridLevelMeanAbsoluteError.ToString("N1")</dd>
                <dt>Grid/year MAPE</dt>
                <dd>@Result.GridLevelMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>Grade total MAE</dt>
                <dd>@Result.GradeMeanAbsoluteError.ToString("N0")</dd>
                <dt>Grade total MAPE</dt>
                <dd>@Result.GradeMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>Grade/year MAE</dt>
                <dd>@Result.GradeLevelMeanAbsoluteError.ToString("N1")</dd>
                <dt>Grade/year MAPE</dt>
                <dd>@Result.GradeLevelMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>HS total MAPE</dt>
                <dd>@Result.HighSchoolMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>HS grade MAPE</dt>
                <dd>@Result.HighSchoolGradeMeanAbsolutePercentageError.ToString("P1")</dd>
                <dt>Combined score</dt>
                <dd>@Result.CombinedScore.ToString("P2")</dd>
            </dl>
        </div>
    </div>
    </ToolPanel>
    }

    @if (IsToolActive(ToolTableDetails))
    {
    <ToolPanel Id="@ToolTableDetails" Title="Table Details" Style="@ToolStyle(ToolTableDetails)"
               Collapsed="@IsToolCollapsed(ToolTableDetails)" CanMoveUp="@CanMoveToolUp(ToolTableDetails)" CanMoveDown="@CanMoveToolDown(ToolTableDetails)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
    <div class="metric-options">
        <label>
            <input type="checkbox" @bind="ShowIncreaseFromStart" />
            <span>Increase from start</span>
        </label>
        <label>
            <input type="checkbox" @bind="ShowIncreaseFromStartPercent" />
            <span>Increase from start %</span>
        </label>
        <label>
            <input type="checkbox" @bind="ShowIncreaseFromPrevious" />
            <span>Increase from previous year</span>
        </label>
        <label>
            <input type="checkbox" @bind="ShowIncreaseFromPreviousPercent" />
            <span>Increase from previous year %</span>
        </label>
    </div>
    </ToolPanel>
    }

    @if (IsToolActive(ToolCohorts))
    {
    <ToolPanel Id="@ToolCohorts" Title="Monte Carlo Progressing Cohorts" Style="@ToolStyle(ToolCohorts)"
               Collapsed="@IsToolCollapsed(ToolCohorts)" CanMoveUp="@CanMoveToolUp(ToolCohorts)" CanMoveDown="@CanMoveToolDown(ToolCohorts)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
    <CohortProgressTable Title="Monte Carlo Progressing Cohorts" Cohorts="MonteCarloProgressingCohorts" Projection="MonteCarloModeledProjection"
                         ReferenceProjection="MonteCarloReferenceProjection"
                         ProgressionGrades="VisibleCohortGrades"
                         ShowIncreaseFromStart="ShowIncreaseFromStart"
                         ShowIncreaseFromStartPercent="ShowIncreaseFromStartPercent"
                         ShowIncreaseFromPrevious="ShowIncreaseFromPrevious"
                         ShowIncreaseFromPreviousPercent="ShowIncreaseFromPreviousPercent" />
    </ToolPanel>
    }
    @if (IsToolActive(ToolGrades))
    {
    <ToolPanel Id="@ToolGrades" Title="Monte Carlo Grades" Style="@ToolStyle(ToolGrades)"
               Collapsed="@IsToolCollapsed(ToolGrades)" CanMoveUp="@CanMoveToolUp(ToolGrades)" CanMoveDown="@CanMoveToolDown(ToolGrades)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
    <ProjectionTable Title="Monte Carlo Grades" Names="VisibleGradeOrder" Projection="MonteCarloModeledProjection" ValueSelector="GradeValue"
                     ReferenceProjection="MonteCarloReferenceProjection"
                     ReferenceValueSelector="GradeValue"
                     Subtotals="GradeSubtotals"
                     ShowIncreaseFromStart="ShowIncreaseFromStart"
                     ShowIncreaseFromStartPercent="ShowIncreaseFromStartPercent"
                     ShowIncreaseFromPrevious="ShowIncreaseFromPrevious"
                     ShowIncreaseFromPreviousPercent="ShowIncreaseFromPreviousPercent" />
    </ToolPanel>
    }
    @if (IsToolActive(ToolGridTotals))
    {
    <ToolPanel Id="@ToolGridTotals" Title="Monte Carlo Grid Totals" Style="@ToolStyle(ToolGridTotals)"
               Collapsed="@IsToolCollapsed(ToolGridTotals)" CanMoveUp="@CanMoveToolUp(ToolGridTotals)" CanMoveDown="@CanMoveToolDown(ToolGridTotals)"
               OnToggle="ToggleTool" OnMoveUp="MoveToolUp" OnMoveDown="MoveToolDown" OnRemove="RemoveTool">
    <ProjectionTable Title="Monte Carlo Grid Totals" Names="MonteCarloGridNames" Projection="MonteCarloModeledProjection" ValueSelector="GridValue"
